     \"product_id\": product[\"id\"],\n67\t            \"available_stock\": product[\"total_stock\"] - product[\"reserved_stock\"],\n68\t            \"reserved_stock\": product[\"reserved_stock\"],\n69\t        }\n70\t\n71\t\n72\tdef set_product_stock(product_id: str, stock: int) -> dict:\n73\t    \"\"\"\n74\t    Update product total stock.\n75\t\n76\t    Args:\n77\t        product_id: The product ID\n78\t        stock: The new total stock quantity\n79\t\n80\t    Returns:\n81\t        The updated product stock info\n82\t    \"\"\"\n83\t    with get_inventory_connection() as conn:\n84\t        product = get_product(conn, product_id)\n85\t        if not product:\n86\t            raise ProductNotFoundError(f\"Product {product_id} not found\")\n87\t\n88\t        # Ensure stock is not less than already reserved\n89\t        if stock < product[\"reserved_stock\"]:\n90\t            raise ValueError(\n91\t                f\"Cannot set stock to {stock}, product has {product['reserved_stock']} reserved\"\n92\t            )\n93\t\n94\t        conn.execute(\n95\t            \"UPDATE products SET total_stock = ? WHERE id = ?\",\n96\t            (stock, product_id)\n97\t        )\n98\t        conn.commit()\n99\t\n100\t    return {\n101\t        \"product_id\": product_id,\n102\t        \"available_stock\": stock - product[\"reserved_stock\"],\n103\t        \"reserved_stock\": product[\"reserved_stock\"],\n104\t    }\n105\t\n106\t\n107\tdef reserve_stock(product_id: str, quantity: int) -> dict:\n108\t    \"\"\"\n109\t    Reserve stock for a product (pre-allocation for an order).\n110\t\n111\t    Args:\n112\t        product_id: The product ID\n113\t        quantity: The quantity to reserve\n114\t\n115\t    Returns:\n116\t        The updated stock info\n117\t\n118\t    Raises:\n119\t        ProductNotFoundError: If the product does not exist\n120\t        InsufficientStockError: If there is not enough available stock\n121\t    \"\"\"\n122\t    with get_inventory_connection() as conn