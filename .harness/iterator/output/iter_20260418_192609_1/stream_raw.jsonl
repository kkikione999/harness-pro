{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_rcv3q66f9ny6_2","type":"tool_result","content":"1\t\"\"\"FastAPI application for the Inventory Service.\"\"\"\n2\t\n3\tfrom fastapi import FastAPI, HTTPException, status\n4\tfrom fastapi.responses import JSONResponse\n5\tfrom contextlib import asynccontextmanager\n6\t\n7\tfrom .models import (\n8\t    StockAdjustRequest,\n9\t    StockResponse,\n10\t    ReserveRequest,\n11\t    ConfirmRequest,\n12\t    ReleaseRequest,\n13\t    ErrorResponse,\n14\t    ProductCreate,\n15\t)\n16\tfrom .services import (\n17\t    get_product_stock_info,\n18\t    set_product_stock,\n19\t    reserve_stock,\n20\t    confirm_deduction,\n21\t    release_reservation,\n22\t    create_product,\n23\t    ProductNotFoundError,\n24\t    InsufficientStockError,\n25\t)\n26\tfrom .database import init_inventory_db\n27\t\n28\t\n29\t@asynccontextmanager\n30\tasync def lifespan(app: FastAPI):\n31\t    \"\"\"Initialize database on startup.\"\"\"\n32\t    init_inventory_db()\n33\t    yield\n34\t\n35\t\n36\tapp = FastAPI(\n37\t    title=\"Inventory Service\",\n38\t    description=\"Manages product inventory, stock reservation, and deduction\",\n39\t    version=\"1.0.0\",\n40\t    lifespan=lifespan,\n41\t)\n42\t\n43\t\n44\t@app.exception_handler(ProductNotFoundError)\n45\tasync def product_not_found_handler(request, exc):\n46\t    return JSONResponse(\n47\t        status_code=status.HTTP_404_NOT_FOUND,\n48\t        content={\"error\": \"Product not found\", \"detail\": str(exc)},\n49\t    )\n50\t\n51\t\n52\t@app.exception_handler(InsufficientStockError)\n53\tasync def insufficient_stock_handler(request, exc):\n54\t    return JSONResponse(\n55\t        status_code=status.HTTP_400_BAD_REQUEST,\n56\t        content={\"error\": \"Insufficient stock\", \"detail\": str(exc)},\n57\t    )\n58\t\n59\t\n60\t@app.exception_handler(ValueError)\n61\tasync def value_error_handler(request, exc):\n62\t    return JSONResponse(\n63\t        status_code=status.HTTP_400_BAD_REQUEST,\n64\t        content={\"error\": \"Bad request\", \"detail\": str(exc)},\n65\t    )\n66\t\n67\t\n68\t@app.post(\"/products\", response_model=StockResponse, status_code=status.HTTP_201_CREATED)\n69\tasync def create_product_endpoint(product_data: ProductCreate):\n70\t    \"\"\"\n71\t    Create a new product with initial stock.\n72\t\n73\t    - **product_id**: The product ID\n74\t    - **name**: The product name (optional, defaults to \"Product\")\n75\t    - **price**: The product price (optional, defaults to 0.0)\n76\t    - **stock**: The initial stock quantity\n77\t    \"\"\"\n78\t    product = create_product(\n79\t        product_data.product_id,\n80\t        product_data.name,\n81\t        product_data.price,\n82\t        product_data.stock\n83\t    )\n84\t\n85\t    return StockResponse(\n86\t        product_id=product[\"id\"],\n87\t        available_stock=product[\"total_stock\"],\n88\t        reserved_stock=0,\n89\t    )\n90\t\n91\t\n92\t@app.post(\"/products/{product_id}/stock\", response_model=StockResponse)\n93\tasync def set_stock_endpoint(product_id: str, stock_data: StockAdjustRequest):\n94\t    \"\"\"\n95\t    Initialize or update product stock.\n96\t\n97\t    - **product_id**: The product ID to update\n98\t    - **stock**: The stock quantity to set\n99\t    \"\"\"\n100\t    stock_info = set_product_stock(product_id, stock_data.stock)\n101\t\n102\t    return StockResponse(\n103\t        product_id=stock_info[\"product_id\"],\n104\t        available_stock=stock_info[\"available_stock\"],\n105\t        reserved_stock=stock_info[\"reserved_stock\"],\n106\t    )\n107\t\n108\t\n109\t@app.get(\"/products/{product_id}/stock\", response_model=StockResponse)\n110\tasync def get_stock_endpoint(product_id: str):\n111\t    \"\"\"\n112\t    Get product stock information.\n113\t\n114\t    - **product_id**: The product ID to query\n115\t    \"\"\"\n116\t    stock_info = get_product_stock_info(product_id)\n117\t    if not stock_info:\n118\t        raise HTTPException(\n119\t            status_code=status.HTTP_404_NOT_FOUND,\n120\t            detail=f\"Product {product_id} not found\",\n121\t        )\n122\t\n123\t    return StockResponse(\n124\t        product_id=stock_info[\"product_id\"],\n125\t        available_stock=stock_info[\"available_stock\"],\n126\t        reserved_stock=stock_info[\"reserved_stock\"],\n127\t    )\n128\t\n129\t\n130\t@app.post(\"/products/{product_id}/reserve\", response_model=StockResponse)\n131\tasync def reserve_stock_endpoint(product_id: str, request: ReserveRequest):\n132\t    \"\"\"\n133\t    Reserve stock for a product (pre-allocation for an order).\n134\t\n135\t    - **product_id**: The product ID\n136\t    - **quantity**: The quantity to reserve\n137\t    \"\"\"\n138\t    stock_info = reserve_stock(product_id, request.quantity)\n139\t\n140\t    return StockResponse(\n141\t        product_id=stock_info[\"product_id\"],\n142\t        available_stock=stock_info[\"available_stock\"],\n143\t        reserved_stock=stock_info[\"reserved_stock\"],\n144\t    )\n145\t\n146\t\n147\t@app.post(\"/products/{product_id}/confirm\", response_model=StockResponse)\n148\tasync def confirm_deduction_endpoint(product_id: str, request: ConfirmRequest):\n149\t    \"\"\"\n150\t    Confirm stock deduction after payment.\n151\t\n152\t    - **product_id**: The product ID\n153\t    - **quantity**: The quantity to confirm/deduct\n154\t    \"\"\"\n155\t    stock_info = confirm_deduction(product_id, request.quantity)\n156\t\n157\t    return StockResponse(\n158\t        product_id=stock_info[\"product_id\"],\n159\t        available_stock=stock_info[\"available_stock\"],\n160\t        reserved_stock=stock_info[\"reserved_stock\"],\n161\t    )\n162\t\n163\t\n164\t@app.post(\"/products/{product_id}/release\", response_model=StockResponse)\n165\tasync def release_reservation_endpoint(product_id: str, request: ReleaseRequest):\n166\t    \"\"\"\n167\t    Release reserved stock (e.g., when order is cancelled).\n168\t\n169\t    - **product_id**: The product ID\n170\t    - **quantity**: The quantity to release\n171\t    \"\"\"\n172\t    stock_info = release_reservation(product_id, request.quantity)\n173\t\n174\t    return StockResponse(\n175\t        product_id=stock_info[\"product_id\"],\n176\t        available_stock=stock_info[\"available_stock\"],\n177\t        reserved_stock=stock_info[\"reserved_stock\"],\n178\t    )\n179\t\n180\t\n181\tif __name__ == \"__main__\":\n182\t    import uvicorn\n183\t    uvicorn.run(app, host=\"0.0.0.0\", port=8082)"}]},"parent_tool_use_id":null,"session_id":"6e8ed865-078c-4fea-8f21-00b59c62bf26","uuid":"8a498e06-c76a-4b1d-838d-b373688cfb5b","timestamp":"2026-04-18T11:27:15.077Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/josh_folder/harness-pro-for-vibe/harness-blogs/order-management-system/inventory_service/main.py","content":"\"\"\"FastAPI application for the Inventory Service.\"\"\"\n\nfrom fastapi import FastAPI, HTTPException, status\nfrom fastapi.responses import JSONResponse\nfrom contextlib import asynccontextmanager\n\nfrom .models import (\n    StockAdjustRequest,\n    StockResponse,\n    ReserveRequest,\n    ConfirmRequest,\n    ReleaseRequest,\n    ErrorResponse,\n    ProductCreate,\n)\nfrom .services import (\n    get_product_stock_info,\n    set_product_stock,\n    reserve_stock,\n    confirm_deduction,\n    release_reservation,\n    create_product,\n    ProductNotFoundError,\n    InsufficientStockError,\n)\nfrom .database import init_inventory_db\n\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    \"\"\"Initialize database on startup.\"\"\"\n    init_inventory_db()\n    yield\n\n\napp = FastAPI(\n    title=\"Inventory Service\",\n    description=\"Manages product inventory, stock reservation, and deduction\",\n    version=\"1.0.0\",\n    lifespan=lifespan,\n)\n\n\n@app.exception_handler(ProductNotFoundError)\nasync def product_not_found_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_404_NOT_FOUND,\n        content={\"error\": \"Product not found\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(InsufficientStockError)\nasync def insufficient_stock_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_400_BAD_REQUEST,\n        content={\"error\": \"Insufficient stock\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(ValueError)\nasync def value_error_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_400_BAD_REQUEST,\n        content={\"error\": \"Bad request\", \"detail\": str(exc)},\n    )\n\n\n@app.post(\"/products\", response_model=StockResponse, status_code=status.HTTP_201_CREATED)\nasync def create_product_endpoint(product_data: ProductCreate):\n    \"\"\"\n    Create a new product with initial stock.\n\n    - **product_id**: The product ID\n    - **name**: The product name (optional, defaults to \"Product\")\n    - **price**: The product price (optional, defaults to 0.0)\n    - **stock**: The initial stock quantity\n    \"\"\"\n    product = create_product(\n        product_data.product_id,\n        product_data.name,\n        product_data.price,\n        product_data.stock\n    )\n\n    return StockResponse(\n        product_id=product[\"id\"],\n        available_stock=product[\"total_stock\"],\n        reserved_stock=0,\n    )\n\n\n@app.post(\"/products/{product_id}/stock\", response_model=StockResponse)\nasync def set_stock_endpoint(product_id: str, stock_data: StockAdjustRequest):\n    \"\"\"\n    Initialize or update product stock.\n\n    - **product_id**: The product ID to update\n    - **stock**: The stock quantity to set\n    \"\"\"\n    stock_info = set_product_stock(product_id, stock_data.stock)\n\n    return StockResponse(\n        product_id=stock_info[\"product_id\"],\n        available_stock=stock_info[\"available_stock\"],\n        reserved_stock=stock_info[\"reserved_stock\"],\n    )\n\n\n@app.get(\"/products/{product_id}/stock\", response_model=StockResponse)\nasync def get_stock_endpoint(product_id: str):\n    \"\"\"\n    Get product stock information.\n\n    - **product_id**: The product ID to query\n    \"\"\"\n    stock_info = get_product_stock_info(product_id)\n    if not stock_info:\n        raise HTTPException(\n            status_code=status.HTTP_404_NOT_FOUND,\n            detail=f\"Product {product_id} not found\",\n        )\n\n    return StockResponse(\n        product_id=stock_info[\"product_id\"],\n        available_stock=stock_info[\"available_stock\"],\n        reserved_stock=stock_info[\"reserved_stock\"],\n    )\n\n\n@app.post(\"/products/{product_id}/reserve\", response_model=StockResponse)\nasync def reserve_stock_endpoint(product_id: str, request: ReserveRequest):\n    \"\"\"\n    Reserve stock for a product (pre-allocation for an order).\n\n    - **product_id**: The product ID\n    - **quantity**: The quantity to reserve\n    \"\"\"\n    stock_info = reserve_stock(product_id, request.quantity)\n\n    return StockResponse(\n        product_id=stock_info[\"product_id\"],\n        available_stock=stock_info[\"available_stock\"],\n        reserved_stock=stock_info[\"reserved_stock\"],\n    )\n\n\n@app.post(\"/products/{product_id}/confirm\", response_model=StockResponse)\nasync def confirm_deduction_endpoint(product_id: str, request: ConfirmRequest):\n    \"\"\"\n    Confirm stock deduction after payment.\n\n    - **product_id**: The product ID\n    - **quantity**: The quantity to confirm/deduct\n    \"\"\"\n    stock_info = confirm_deduction(product_id, request.quantity)\n\n    return StockResponse(\n        product_id=stock_info[\"product_id\"],\n        available_stock=stock_info[\"available_stock\"],\n        reserved_stock=stock_info[\"reserved_stock\"],\n    )\n\n\n@app.post(\"/products/{product_id}/release\", response_model=StockResponse)\nasync def release_reservation_endpoint(product_id: str, request: ReleaseRequest):\n    \"\"\"\n    Release reserved stock (e.g., when order is cancelled).\n\n    - **product_id**: The product ID\n    - **quantity**: The quantity to release\n    \"\"\"\n    stock_info = release_reservation(product_id, request.quantity)\n\n    return StockResponse(\n        product_id=stock_info[\"product_id\"],\n        available_stock=stock_info[\"available_stock\"],\n        reserved_stock=stock_info[\"reserved_stock\"],\n    )\n\n\nif __name__ == \"__main__\":\n    import uvicorn\n    uvicorn.run(app, host=\"0.0.0.0\", port=8082)","numLines":183,"startLine":1,"totalLines":183}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_rcv3q66f9ny6_1","type":"tool_result","content":"1\t\"\"\"FastAPI application for the Order Service.\"\"\"\n2\t\n3\tfrom fastapi import FastAPI, HTTPException, status\n4\tfrom fastapi.responses import JSONResponse\n5\tfrom contextlib import asynccontextmanager\n6\t\n7\tfrom .models import (\n8\t    OrderCreate,\n9\t    OrderResponse,\n10\t    ErrorResponse,\n11\t)\n12\tfrom .services import (\n13\t    create_order,\n14\t    get_order,\n15\t    pay_order,\n16\t    cancel_order,\n17\t    OrderNotFoundError,\n18\t    InvalidOrderStateError,\n19\t    ServiceUnavailableError,\n20\t)\n21\tfrom .inventory_client import (\n22\t    ProductNotFoundError,\n23\t    InsufficientStockError,\n24\t    InventoryServiceError,\n25\t    ServiceConnectionError,\n26\t)\n27\tfrom .database import init_orders_db\n28\t\n29\t\n30\t@asynccontextmanager\n31\tasync def lifespan(app: FastAPI):\n32\t    \"\"\"Initialize database on startup.\"\"\"\n33\t    init_orders_db()\n34\t    yield\n35\t\n36\t\n37\tapp = FastAPI(\n38\t    title=\"Order Service\",\n39\t    description=\"Manages order CRUD, state machine, and coordinates with Inventory Service\",\n40\t    version=\"1.0.0\",\n41\t    lifespan=lifespan,\n42\t)\n43\t\n44\t\n45\t@app.exception_handler(OrderNotFoundError)\n46\tasync def order_not_found_handler(request, exc):\n47\t    return JSONResponse(\n48\t        status_code=status.HTTP_404_NOT_FOUND,\n49\t        content={\"error\": \"Order not found\", \"detail\": str(exc)},\n50\t    )\n51\t\n52\t\n53\t@app.exception_handler(InsufficientStockError)\n54\tasync def insufficient_stock_handler(request, exc):\n55\t    return JSONResponse(\n56\t        status_code=status.HTTP_400_BAD_REQUEST,\n57\t        content={\"error\": \"Insufficient stock\", \"detail\": str(exc)},\n58\t    )\n59\t\n60\t\n61\t@app.exception_handler(ProductNotFoundError)\n62\tasync def product_not_found_handler(request, exc):\n63\t    return JSONResponse(\n64\t        status_code=status.HTTP_404_NOT_FOUND,\n65\t        content={\"error\": \"Product not found\", \"detail\": str(exc)},\n66\t    )\n67\t\n68\t\n69\t@app.exception_handler(InvalidOrderStateError)\n70\tasync def invalid_order_state_handler(request, exc):\n71\t    return JSONResponse(\n72\t        status_code=status.HTTP_400_BAD_REQUEST,\n73\t        content={\"error\": \"Invalid order state\", \"detail\": str(exc)},\n74\t    )\n75\t\n76\t\n77\t@app.exception_handler(ServiceUnavailableError)\n78\tasync def service_unavailable_handler(request, exc):\n79\t    return JSONResponse(\n80\t        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n81\t        content={\"error\": \"Service unavailable\", \"detail\": str(exc)},\n82\t    )\n83\t\n84\t\n85\t@app.exception_handler(ServiceConnectionError)\n86\tasync def service_connection_error_handler(request, exc):\n87\t    return JSONResponse(\n88\t        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n89\t        content={\"error\": \"Service unavailable\", \"detail\": str(exc)},\n90\t    )\n91\t\n92\t\n93\t@app.exception_handler(InventoryServiceError)\n94\tasync def inventory_service_error_handler(request, exc):\n95\t    return JSONResponse(\n96\t        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n97\t        content={\"error\": \"Inventory Service error\", \"detail\": str(exc)},\n98\t    )\n99\t\n100\t\n101\t@app.post(\"/orders\", response_model=OrderResponse, status_code=status.HTTP_201_CREATED)\n102\tasync def create_new_order(order_data: OrderCreate):\n103\t    \"\"\"\n104\t    Create a new order with inventory reservation.\n105\t\n106\t    - **user_id**: The user ID placing the order\n107\t    - **items**: List of items with product_id and quantity\n108\t\n109\t    This endpoint calls the Inventory Service to reserve stock.\n110\t    \"\"\"\n111\t    items = [{\"product_id\": item.product_id, \"quantity\": item.quantity} for item in order_data.items]\n112\t    order = create_order(order_data.user_id, items)\n113\t\n114\t    return OrderResponse(\n115\t        id=order[\"id\"],\n116\t        user_id=order[\"user_id\"],\n117\t        status=order[\"status\"],\n118\t        items=[\n119\t            {\n120\t                \"product_id\": item[\"product_id\"],\n121\t                \"quantity\": item[\"quantity\"],\n122\t                \"unit_price\": item[\"unit_price\"],\n123\t            }\n124\t            for item in order[\"items\"]\n125\t        ],\n126\t        total_amount=order[\"total_amount\"],\n127\t        created_at=order[\"created_at\"],\n128\t    )\n129\t\n130\t\n131\t@app.get(\"/orders/{order_id}\", response_model=OrderResponse)\n132\tasync def get_order_details(order_id: str):\n133\t    \"\"\"\n134\t    Get order details by ID.\n135\t\n136\t    - **order_id**: The order ID to retrieve\n137\t    \"\"\"\n138\t    order = get_order(order_id)\n139\t    if not order:\n140\t        raise HTTPException(\n141\t            status_code=status.HTTP_404_NOT_FOUND,\n142\t            detail=f\"Order {order_id} not found\",\n143\t        )\n144\t\n145\t    return OrderResponse(\n146\t        id=order[\"id\"],\n147\t        user_id=order[\"user_id\"],\n148\t        status=order[\"status\"],\n149\t        items=[\n150\t            {\n151\t                \"product_id\": item[\"product_id\"],\n152\t                \"quantity\": item[\"quantity\"],\n153\t                \"unit_price\": item[\"unit_price\"],\n154\t            }\n155\t            for item in order[\"items\"]\n156\t        ],\n157\t        total_amount=order[\"total_amount\"],\n158\t        created_at=order[\"created_at\"],\n159\t    )\n160\t\n161\t\n162\t@app.post(\"/orders/{order_id}/pay\", response_model=OrderResponse)\n163\tasync def pay_order_endpoint(order_id: str):\n164\t    \"\"\"\n165\t    Pay for an order.\n166\t\n167\t    This endpoint calls the Inventory Service to confirm stock deduction.\n168\t\n169\t    - **order_id**: The order ID to pay\n170\t    \"\"\"\n171\t    order = pay_order(order_id)\n172\t\n173\t    return OrderResponse(\n174\t        id=order[\"id\"],\n175\t        user_id=order[\"user_id\"],\n176\t        status=order[\"status\"],\n177\t        items=[\n178\t            {\n179\t                \"product_id\": item[\"product_id\"],\n180\t                \"quantity\": item[\"quantity\"],\n181\t                \"unit_price\": item[\"unit_price\"],\n182\t            }\n183\t            for item in order[\"items\"]\n184\t        ],\n185\t        total_amount=order[\"total_amount\"],\n186\t        created_at=order[\"created_at\"],\n187\t    )\n188\t\n189\t\n190\t@app.post(\"/orders/{order_id}/cancel\", response_model=OrderResponse)\n191\tasync def cancel_order_endpoint(order_id: str):\n192\t    \"\"\"\n193\t    Cancel an order.\n194\t\n195\t    This endpoint calls the Inventory Service to release reserved stock.\n196\t\n197\t    - **order_id**: The order ID to cancel\n198\t    \"\"\"\n199\t    order = cancel_order(order_id)\n200\t\n201\t    return OrderResponse(\n202\t        id=order[\"id\"],\n203\t        user_id=order[\"user_id\"],\n204\t        status=order[\"status\"],\n205\t        items=[\n206\t            {\n207\t                \"product_id\": item[\"product_id\"],\n208\t                \"quantity\": item[\"quantity\"],\n209\t                \"unit_price\": item[\"unit_price\"],\n210\t            }\n211\t            for item in order[\"items\"]\n212\t        ],\n213\t        total_amount=order[\"total_amount\"],\n214\t        created_at=order[\"created_at\"],\n215\t    )\n216\t\n217\t\n218\tif __name__ == \"__main__\":\n219\t    import uvicorn\n220\t    uvicorn.run(app, host=\"0.0.0.0\", port=8081)"}]},"parent_tool_use_id":null,"session_id":"6e8ed865-078c-4fea-8f21-00b59c62bf26","uuid":"0da1b2ab-f01d-4327-a04b-0c5ab21e51e7","timestamp":"2026-04-18T11:27:15.078Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/josh_folder/harness-pro-for-vibe/harness-blogs/order-management-system/order_service/main.py","content":"\"\"\"FastAPI application for the Order Service.\"\"\"\n\nfrom fastapi import FastAPI, HTTPException, status\nfrom fastapi.responses import JSONResponse\nfrom contextlib import asynccontextmanager\n\nfrom .models import (\n    OrderCreate,\n    OrderResponse,\n    ErrorResponse,\n)\nfrom .services import (\n    create_order,\n    get_order,\n    pay_order,\n    cancel_order,\n    OrderNotFoundError,\n    InvalidOrderStateError,\n    ServiceUnavailableError,\n)\nfrom .inventory_client import (\n    ProductNotFoundError,\n    InsufficientStockError,\n    InventoryServiceError,\n    ServiceConnectionError,\n)\nfrom .database import init_orders_db\n\n\n@asynccontextmanager\nasync def lifespan(app: FastAPI):\n    \"\"\"Initialize database on startup.\"\"\"\n    init_orders_db()\n    yield\n\n\napp = FastAPI(\n    title=\"Order Service\",\n    description=\"Manages order CRUD, state machine, and coordinates with Inventory Service\",\n    version=\"1.0.0\",\n    lifespan=lifespan,\n)\n\n\n@app.exception_handler(OrderNotFoundError)\nasync def order_not_found_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_404_NOT_FOUND,\n        content={\"error\": \"Order not found\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(InsufficientStockError)\nasync def insufficient_stock_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_400_BAD_REQUEST,\n        content={\"error\": \"Insufficient stock\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(ProductNotFoundError)\nasync def product_not_found_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_404_NOT_FOUND,\n        content={\"error\": \"Product not found\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(InvalidOrderStateError)\nasync def invalid_order_state_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_400_BAD_REQUEST,\n        content={\"error\": \"Invalid order state\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(ServiceUnavailableError)\nasync def service_unavailable_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n        content={\"error\": \"Service unavailable\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(ServiceConnectionError)\nasync def service_connection_error_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n        content={\"error\": \"Service unavailable\", \"detail\": str(exc)},\n    )\n\n\n@app.exception_handler(InventoryServiceError)\nasync def inventory_service_error_handler(request, exc):\n    return JSONResponse(\n        status_code=status.HTTP_503_SERVICE_UNAVAILABLE,\n        content={\"error\": \"Inventory Service error\", \"detail\": str(exc)},\n    )\n\n\n@app.post(\"/orders\", response_model=OrderResponse, status_code=status.HTTP_201_CREATED)\nasync def create_new_order(order_data: OrderCreate):\n    \"\"\"\n    Create a new order with inventory reservation.\n\n    - **user_id**: The user ID placing the order\n    - **items**: List of items with product_id and quantity\n\n    This endpoint calls the Inventory Service to reserve stock.\n    \"\"\"\n    items = [{\"product_id\": item.product_id, \"quantity\": item.quantity} for item in order_data.items]\n    order = create_order(order_data.user_id, items)\n\n    return OrderResponse(\n        id=order[\"id\"],\n        user_id=order[\"user_id\"],\n        status=order[\"status\"],\n        items=[\n            {\n                \"product_id\": item[\"product_id\"],\n                \"quantity\": item[\"quantity\"],\n                \"unit_price\": item[\"unit_price\"],\n            }\n            for item in order[\"items\"]\n        ],\n        total_amount=order[\"total_amount\"],\n        created_at=order[\"created_at\"],\n    )\n\n\n@app.get(\"/orders/{order_id}\", response_model=OrderResponse)\nasync def get_order_details(order_id: str):\n    \"\"\"\n    Get order details by ID.\n\n    - **order_id**: The order ID to retrieve\n    \"\"\"\n    order = get_order(order_id)\n    if not order:\n        raise HTTPException(\n            status_code=status.HTTP_404_NOT_FOUND,\n            detail=f\"Order {order_id} not found\",\n        )\n\n    return OrderResponse(\n        id=order[\"id\"],\n        user_id=order[\"user_id\"],\n        status=order[\"status\"],\n        items=[\n            {\n                \"product_id\": item[\"product_id\"],\n                \"quantity\": item[\"quantity\"],\n                \"unit_price\": item[\"unit_price\"],\n            }\n            for item in order[\"items\"]\n        ],\n        total_amount=order[\"total_amount\"],\n        created_at=order[\"created_at\"],\n    )\n\n\n@app.post(\"/orders/{order_id}/pay\", response_model=OrderResponse)\nasync def pay_order_endpoint(order_id: str):\n    \"\"\"\n    Pay for an order.\n\n    This endpoint calls the Inventory Service to confirm stock deduction.\n\n    - **order_id**: The order ID to pay\n    \"\"\"\n    order = pay_order(order_id)\n\n    return OrderResponse(\n        id=order[\"id\"],\n        user_id=order[\"user_id\"],\n        status=order[\"status\"],\n        items=[\n            {\n                \"product_id\": item[\"product_id\"],\n                \"quantity\": item[\"quantity\"],\n                \"unit_price\": item[\"unit_price\"],\n            }\n            for item in order[\"items\"]\n        ],\n        total_amount=order[\"total_amount\"],\n        created_at=order[\"created_at\"],\n    )\n\n\n@app.post(\"/orders/{order_id}/cancel\", response_model=OrderResponse)\nasync def cancel_order_endpoint(order_id: str):\n    \"\"\"\n    Cancel an order.\n\n    This endpoint calls the Inventory Service to release reserved stock.\n\n    - **order_id**: The order ID to cancel\n    \"\"\"\n    order = cancel_order(order_id)\n\n    return OrderResponse(\n        id=order[\"id\"],\n        user_id=order[\"user_id\"],\n        status=order[\"status\"],\n        items=[\n            {\n                \"product_id\": item[\"product_id\"],\n                \"quantity\": item[\"quantity\"],\n                \"unit_price\": item[\"unit_price\"],\n            }\n            for item in order[\"items\"]\n        ],\n        total_amount=order[\"total_amount\"],\n        created_at=order[\"created_at\"],\n    )\n\n\nif __name__ == \"__main__\":\n    import uvicorn\n    uvicorn.run(app, host=\"0.0.0.0\", port=8081)","numLines":220,"startLine":1,"totalLines":220}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_rcv3q66f9ny6_3","type":"tool_result","content":"1\t\"\"\"Business logic services for Order Service.\"\"\"\n2\t\n3\timport uuid\n4\tfrom datetime import datetime\n5\tfrom typing import Optional\n6\t\n7\tfrom .database import (\n8\t    get_orders_connection,\n9\t)\n10\tfrom .models import OrderStatus\n11\tfrom .inventory_client import (\n12\t    reserve_stock,\n13\t    release_stock,\n14\t    confirm_stock,\n15\t    ProductNotFoundError,\n16\t    InsufficientStockError,\n17\t    InventoryServiceError,\n18\t    ServiceConnectionError,\n19\t)\n20\t\n21\t\n22\tclass OrderNotFoundError(Exception):\n23\t    \"\"\"Raised when an order is not found.\"\"\"\n24\t    pass\n25\t\n26\t\n27\tclass InvalidOrderStateError(Exception):\n28\t    \"\"\"Raised when an operation is invalid for the current order state.\"\"\"\n29\t    pass\n30\t\n31\t\n32\tclass ServiceUnavailableError(Exception):\n33\t    \"\"\"Raised when the Inventory Service is unavailable.\"\"\"\n34\t    pass\n35\t\n36\t\n37\tdef generate_order_id() -> str:\n38\t    \"\"\"Generate a unique order ID.\"\"\"\n39\t    return f\"ORD-{uuid.uuid4().hex[:12].upper()}\"\n40\t\n41\t\n42\tdef create_order(user_id: str, items: list[dict]) -> dict:\n43\t    \"\"\"\n44\t    Create a new order with inventory reservation.\n45\t\n46\t    Args:\n47\t        user_id: The user ID\n48\t        items: List of items [{\"product_id\": \"...\", \"quantity\": N}]\n49\t\n50\t    Returns:\n51\t        The created order dict\n52\t\n53\t    Raises:\n54\t        InsufficientStockError: If stock is not available\n55\t        ProductNotFoundError: If a product does not exist\n56\t        ServiceUnavailableError: If Inventory Service is unavailable\n57\t    \"\"\"\n58\t    order_id = generate_order_id()\n59\t    created_at = datetime.utcnow().isoformat()\n60\t\n61\t    # First, reserve stock for all items via Inventory Service\n62\t    reserved_items = []\n63\t    try:\n64\t        for item in items:\n65\t            product_id = item[\"product_id\"]\n66\t            quantity = item[\"quantity\"]\n67\t\n68\t            # Call Inventory Service to reserve stock\n69\t            # The response includes available_stock and reserved_stock but not price\n70\t            # We need to track what we reserved\n71\t            stock_info = reserve_stock(product_id, quantity)\n72\t\n73\t            reserved_items.append({\n74\t                \"product_id\": product_id,\n75\t                \"quantity\": quantity,\n76\t                \"unit_price\": 0.0,  # Price is not provided by inventory service\n77\t            })\n78\t    except (ProductNotFoundError, InsufficientStockError, InventoryServiceError, ServiceConnectionError) as e:\n79\t        # Rollback all previously reserved stock\n80\t        for item in reserved_items:\n81\t            try:\n82\t                release_stock(item[\"product_id\"], item[\"quantity\"])\n83\t            except Exception:\n84\t                pass  # Best effort rollback\n85\t        raise e\n86\t\n87\t    # Now create the order with placeholder prices (0.0)\n88\t    # Note: In a real system, we'd get prices from Inventory Service or a catalog\n89\t    total_amount = sum(item[\"unit_price\"] * item[\"quantity\"] for item in reserved_items)\n90\t\n91\t    try:\n92\t        with get_orders_connection() as order_conn:\n93\t            order_conn.execute(\n94\t                \"INSERT INTO orders (id, user_id, status, total_amount, created_at) \"\n95\t                \"VALUES (?, ?, ?, ?, ?)\",\n96\t                (order_id, user_id, OrderStatus.PENDING.value, total_amount, created_at)\n97\t            )\n98\t\n99\t            for item in reserved_items:\n100\t                order_conn.execute(\n101\t                    \"INSERT INTO order_items (order_id, product_id, quantity, unit_price) \"\n102\t                    \"VALUES (?, ?, ?, ?)\",\n103\t                    (order_id, item[\"product_id\"], item[\"quantity\"], item[\"unit_price\"])\n104\t                )\n105\t\n106\t            order_conn.commit()\n107\t    except Exception as e:\n108\t        # Rollback stock reservations if order creation fails\n109\t        for item in reserved_items:\n110\t            try:\n111\t                release_stock(item[\"product_id\"], item[\"quantity\"])\n112\t            except Exception:\n113\t                pass  # Best effort rollback\n114\t        raise e\n115\t\n116\t    return {\n117\t        \"id\": order_id,\n118\t        \"user_id\": user_id,\n119\t        \"status\": OrderStatus.PENDING.value,\n120\t        \"items\": reserved_items,\n121\t        \"total_amount\": total_amount,\n122\t        \"created_at\": created_at,\n123\t    }\n124\t\n125\t\n126\tdef get_order(order_id: str) -> Optional[dict]:\n127\t    \"\"\"Get order by ID.\"\"\"\n128\t    with get_orders_connection() as conn:\n129\t        cursor = conn.execute(\n130\t            \"SELECT id, user_id, status, total_amount, created_at FROM orders WHERE id = ?\",\n131\t            (order_id,)\n132\t        )\n133\t        row = cursor.fetchone()\n134\t        if not row:\n135\t            return None\n136\t\n137\t        cursor = conn.execute(\n138\t            \"SELECT product_id, quantity, unit_price FROM order_items WHERE order_id = ?\",\n139\t            (order_id,)\n140\t        )\n141\t        items = [\n142\t            {\n143\t                \"product_id\": item[\"product_id\"],\n144\t                \"quantity\": item[\"quantity\"],\n145\t                \"unit_price\": item[\"unit_price\"],\n146\t            }\n147\t            for item in cursor.fetchall()\n148\t        ]\n149\t\n150\t        return {\n151\t            \"id\": row[\"id\"],\n152\t            \"user_id\": row[\"user_id\"],\n153\t            \"status\": row[\"status\"],\n154\t            \"items\": items,\n155\t            \"total_amount\": row[\"total_amount\"],\n156\t            \"created_at\": row[\"created_at\"],\n157\t        }\n158\t\n159\t\n160\tdef pay_order(order_id: str) -> dict:\n161\t    \"\"\"\n162\t    Pay for an order and confirm stock deduction.\n163\t\n164\t    Args:\n165\t        order_id: The order ID\n166\t\n167\t    Returns:\n168\t        The updated order dict\n169\t\n170\t    Raises:\n171\t        OrderNotFoundError: If the order does not exist\n172\t        InvalidOrderStateError: If the order is not in pending state\n173\t        ServiceUnavailableError: If the Inventory Service is unavailable\n174\t    \"\"\"\n175\t    order = get_order(order_id)\n176\t    if not order:\n177\t        raise OrderNotFoundError(f\"Order {order_id} not found\")\n178\t\n179\t    if order[\"status\"] != OrderStatus.PENDING.value:\n180\t        raise InvalidOrderStateError(\n181\t            f\"Cannot pay order in {order['status']} state. Must be pending.\"\n182\t        )\n183\t\n184\t    # Confirm stock deduction for each item via Inventory Service\n185\t    try:\n186\t        for item in order[\"items\"]:\n187\t            confirm_stock(item[\"product_id\"], item[\"quantity\"])\n188\t    except (ProductNotFoundError, InventoryServiceError) as e:\n189\t        raise ServiceUnavailableError(f\"Failed to confirm stock: {e}\")\n190\t\n191\t    # Update order status to paid\n192\t    with get_orders_connection() as order_conn:\n193\t        order_conn.execute(\n194\t            \"UPDATE orders SET status = ? WHERE id = ?\",\n195\t            (OrderStatus.PAID.value, order_id)\n196\t        )\n197\t        order_conn.commit()\n198\t\n199\t    order[\"status\"] = OrderStatus.PAID.value\n200\t    return order\n201\t\n202\t\n203\tdef cancel_order(order_id: str) -> dict:\n204\t    \"\"\"\n205\t    Cancel an order and release reserved stock.\n206\t\n207\t    Args:\n208\t        order_id: The order ID\n209\t\n210\t    Returns:\n211\t        The updated order dict\n212\t\n213\t    Raises:\n214\t        OrderNotFoundError: If the order does not exist\n215\t        InvalidOrderStateError: If the order cannot be cancelled\n216\t        ServiceUnavailableError: If the Inventory Service is unavailable\n217\t    \"\"\"\n218\t    order = get_order(order_id)\n219\t    if not order:\n220\t        raise OrderNotFoundError(f\"Order {order_id} not found\")\n221\t\n222\t    if order[\"status\"] not in [OrderStatus.PENDING.value]:\n223\t        raise InvalidOrderStateError(\n224\t            f\"Cannot cancel order in {order['status']} state. Only pending orders can be cancelled.\"\n225\t        )\n226\t\n227\t    # Release reserved stock for each item via Inventory Service\n228\t    try:\n229\t        for item in order[\"items\"]:\n230\t            release_stock(item[\"product_id\"], item[\"quantity\"])\n231\t    except (ProductNotFoundError, InventoryServiceError) as e:\n232\t        raise ServiceUnavailableError(f\"Failed to release stock: {e}\")\n233\t\n234\t    # Update order status to cancelled\n235\t    with get_orders_connection() as order_conn:\n236\t        order_conn.execute(\n237\t            \"UPDATE orders SET status = ? WHERE id = ?\",\n238\t            (OrderStatus.CANCELLED.value, order_id)\n239\t        )\n240\t        order_conn.commit()\n241\t\n242\t    order[\"status\"] = OrderStatus.CANCELLED.value\n243\t    return order"}]},"parent_tool_use_id":null,"session_id":"6e8ed865-078c-4fea-8f21-00b59c62bf26","uuid":"e83e2499-43c1-454a-82e3-ff7a1eafedfe","timestamp":"2026-04-18T11:27:15.078Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/josh_folder/harness-pro-for-vibe/harness-blogs/order-management-system/order_service/services.py","content":"\"\"\"Business logic services for Order Service.\"\"\"\n\nimport uuid\nfrom datetime import datetime\nfrom typing import Optional\n\nfrom .database import (\n    get_orders_connection,\n)\nfrom .models import OrderStatus\nfrom .inventory_client import (\n    reserve_stock,\n    release_stock,\n    confirm_stock,\n    ProductNotFoundError,\n    InsufficientStockError,\n    InventoryServiceError,\n    ServiceConnectionError,\n)\n\n\nclass OrderNotFoundError(Exception):\n    \"\"\"Raised when an order is not found.\"\"\"\n    pass\n\n\nclass InvalidOrderStateError(Exception):\n    \"\"\"Raised when an operation is invalid for the current order state.\"\"\"\n    pass\n\n\nclass ServiceUnavailableError(Exception):\n    \"\"\"Raised when the Inventory Service is unavailable.\"\"\"\n    pass\n\n\ndef generate_order_id() -> str:\n    \"\"\"Generate a unique order ID.\"\"\"\n    return f\"ORD-{uuid.uuid4().hex[:12].upper()}\"\n\n\ndef create_order(user_id: str, items: list[dict]) -> dict:\n    \"\"\"\n    Create a new order with inventory reservation.\n\n    Args:\n        user_id: The user ID\n        items: List of items [{\"product_id\": \"...\", \"quantity\": N}]\n\n    Returns:\n        The created order dict\n\n    Raises:\n        InsufficientStockError: If stock is not available\n        ProductNotFoundError: If a product does not exist\n        ServiceUnavailableError: If Inventory Service is unavailable\n    \"\"\"\n    order_id = generate_order_id()\n    created_at = datetime.utcnow().isoformat()\n\n    # First, reserve stock for all items via Inventory Service\n    reserved_items = []\n    try:\n        for item in items:\n            product_id = item[\"product_id\"]\n            quantity = item[\"quantity\"]\n\n            # Call Inventory Service to reserve stock\n            # The response includes available_stock and reserved_stock but not price\n            # We need to track what we reserved\n            stock_info = reserve_stock(product_id, quantity)\n\n            reserved_items.append({\n                \"product_id\": product_id,\n                \"quantity\": quantity,\n                \"unit_price\": 0.0,  # Price is not provided by inventory service\n            })\n    except (ProductNotFoundError, InsufficientStockError, InventoryServiceError, ServiceConnectionError) as e:\n        # Rollback all previously reserved stock\n        for item in reserved_items:\n            try:\n                release_stock(item[\"product_id\"], item[\"quantity\"])\n            except Exception:\n                pass  # Best effort rollback\n        raise e\n\n    # Now create the order with placeholder prices (0.0)\n    # Note: In a real system, we'd get prices from Inventory Service or a catalog\n    total_amount = sum(item[\"unit_price\"] * item[\"quantity\"] for item in reserved_items)\n\n    try:\n        with get_orders_connection() as order_conn:\n            order_conn.execute(\n                \"INSERT INTO orders (id, user_id, status, total_amount, created_at) \"\n                \"VALUES (?, ?, ?, ?, ?)\",\n                (order_id, user_id, OrderStatus.PENDING.value, total_amount, created_at)\n            )\n\n            for item in reserved_items:\n                order_conn.execute(\n                    \"INSERT INTO order_items (order_id, product_id, quantity, unit_price) \"\n                    \"VALUES (?, ?, ?, ?)\",\n                    (order_id, item[\"product_id\"], item[\"quantity\"], item[\"unit_price\"])\n                )\n\n            order_conn.commit()\n    except Exception as e:\n        # Rollback stock reservations if order creation fails\n        for item in reserved_items:\n            try:\n                release_stock(item[\"product_id\"], item[\"quantity\"])\n            except Exception:\n                pass  # Best effort rollback\n        raise e\n\n    return {\n        \"id\": order_id,\n        \"user_id\": user_id,\n        \"status\": OrderStatus.PENDING.value,\n        \"items\": reserved_items,\n        \"total_amount\": total_amount,\n        \"created_at\": created_at,\n    }\n\n\ndef get_order(order_id: str) -> Optional[dict]:\n    \"\"\"Get order by ID.\"\"\"\n    with get_orders_connection() as conn:\n        cursor = conn.execute(\n            \"SELECT id, user_id, status, total_amount, created_at FROM orders WHERE id = ?\",\n            (order_id,)\n        )\n        row = cursor.fetchone()\n        if not row:\n            return None\n\n        cursor = conn.execute(\n            \"SELECT product_id, quantity, unit_price FROM order_items WHERE order_id = ?\",\n            (order_id,)\n        )\n        items = [\n            {\n                \"product_id\": item[\"product_id\"],\n                \"quantity\": item[\"quantity\"],\n                \"unit_price\": item[\"unit_price\"],\n            }\n            for item in cursor.fetchall()\n        ]\n\n        return {\n            \"id\": row[\"id\"],\n            \"user_id\": row[\"user_id\"],\n            \"status\": row[\"status\"],\n            \"items\": items,\n            \"total_amount\": row[\"total_amount\"],\n            \"created_at\": row[\"created_at\"],\n        }\n\n\ndef pay_order(order_id: str) -> dict:\n    \"\"\"\n    Pay for an order and confirm stock deduction.\n\n    Args:\n        order_id: The order ID\n\n    Returns:\n        The updated order dict\n\n    Raises:\n        OrderNotFoundError: If the order does not exist\n        InvalidOrderStateError: If the order is not in pending state\n        ServiceUnavailableError: If the Inventory Service is unavailable\n    \"\"\"\n    order = get_order(order_id)\n    if not order:\n        raise OrderNotFoundError(f\"Order {order_id} not found\")\n\n    if order[\"status\"] != OrderStatus.PENDING.value:\n        raise InvalidOrderStateError(\n            f\"Cannot pay order in {order['status']} state. Must be pending.\"\n        )\n\n    # Confirm stock deduction for each item via Inventory Service\n    try:\n        for item in order[\"items\"]:\n            confirm_stock(item[\"product_id\"], item[\"quantity\"])\n    except (ProductNotFoundError, InventoryServiceError) as e:\n        raise ServiceUnavailableError(f\"Failed to confirm stock: {e}\")\n\n    # Update order status to paid\n    with get_orders_connection() as order_conn:\n        order_conn.execute(\n            \"UPDATE orders SET status = ? WHERE id = ?\",\n            (OrderStatus.PAID.value, order_id)\n        )\n        order_conn.commit()\n\n    order[\"status\"] = OrderStatus.PAID.value\n    return order\n\n\ndef cancel_order(order_id: str) -> dict:\n    \"\"\"\n    Cancel an order and release reserved stock.\n\n    Args:\n        order_id: The order ID\n\n    Returns:\n        The updated order dict\n\n    Raises:\n        OrderNotFoundError: If the order does not exist\n        InvalidOrderStateError: If the order cannot be cancelled\n        ServiceUnavailableError: If the Inventory Service is unavailable\n    \"\"\"\n    order = get_order(order_id)\n    if not order:\n        raise OrderNotFoundError(f\"Order {order_id} not found\")\n\n    if order[\"status\"] not in [OrderStatus.PENDING.value]:\n        raise InvalidOrderStateError(\n            f\"Cannot cancel order in {order['status']} state. Only pending orders can be cancelled.\"\n        )\n\n    # Release reserved stock for each item via Inventory Service\n    try:\n        for item in order[\"items\"]:\n            release_stock(item[\"product_id\"], item[\"quantity\"])\n    except (ProductNotFoundError, InventoryServiceError) as e:\n        raise ServiceUnavailableError(f\"Failed to release stock: {e}\")\n\n    # Update order status to cancelled\n    with get_orders_connection() as order_conn:\n        order_conn.execute(\n            \"UPDATE orders SET status = ? WHERE id = ?\",\n            (OrderStatus.CANCELLED.value, order_id)\n        )\n        order_conn.commit()\n\n    order[\"status\"] = OrderStatus.CANCELLED.value\n    return order","numLines":243,"startLine":1,"totalLines":243}}}
