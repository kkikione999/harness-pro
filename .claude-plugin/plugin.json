{
  "name": "harness-pro-plugin",
  "version": "1.2.0",
  "description": "Coordinator skill for long, multi-step development tasks. Orchestrates plan-agent, worker, reviewer, and teammate through an 8-step pipeline. Bundles utell-ios MCP server for iOS simulator automation, plus LSP support for TypeScript, Swift, Go, and Python.",
  "author": {
    "name": "josh-folder"
  },
  "license": "MIT",
  "keywords": ["orchestration", "planning", "code-review", "e2e", "workflow", "harness-engineering", "lsp", "ios", "simulator", "typescript", "swift", "go", "python"],
  "skills": "./skills/",
  "agents": [
    "./agents/plan-agent.md",
    "./agents/worker.md",
    "./agents/reviewer.md",
    "./agents/teammate.md"
  ],
  "userConfig": {
    "UTELL_BUNDLE_ID": {
      "type": "string",
      "title": "iOS App Bundle ID",
      "description": "The bundle identifier of your iOS app (e.g., com.example.myapp). Required for utell-ios MCP server.",
      "required": true
    },
    "UTELL_WDA_HOST": {
      "type": "string",
      "title": "WDA Host",
      "description": "WebDriverAgent host address. Defaults to 127.0.0.1.",
      "required": false
    },
    "UTELL_WDA_PORT": {
      "type": "string",
      "title": "WDA Port",
      "description": "WebDriverAgent port. Defaults to 8100.",
      "required": false
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-push-simplify.sh\"",
            "if": "Bash(git push*)",
            "timeout": 10,
            "statusMessage": "Checking if /simplify review is needed before push..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/install-lsp-deps.sh\"",
            "timeout": 120,
            "statusMessage": "Checking LSP dependencies..."
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "utell-ios": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/utell-ios/run.sh"],
      "env": {
        "UTELL_BUNDLE_ID": "${user_config.UTELL_BUNDLE_ID}",
        "UTELL_WDA_HOST": "${user_config.UTELL_WDA_HOST}",
        "UTELL_WDA_PORT": "${user_config.UTELL_WDA_PORT}"
      }
    }
  },
  "lspServers": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mts": "typescript",
        ".cts": "typescript",
        ".mjs": "javascript",
        ".cjs": "javascript"
      }
    },
    "sourcekit-lsp": {
      "command": "sourcekit-lsp",
      "extensionToLanguage": {
        ".swift": "swift"
      }
    },
    "gopls": {
      "command": "gopls",
      "extensionToLanguage": {
        ".go": "go"
      }
    },
    "pyright": {
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
