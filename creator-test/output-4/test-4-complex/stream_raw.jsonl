{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_d04ol0adhre1_1","type":"tool_result","content":"1\timport XCTest\n2\t@testable import MarkdownPreview\n3\t\n4\t@MainActor\n5\tfinal class AppStateTests: XCTestCase {\n6\t    func testOpenSetsDocumentAndWindowTitle() throws {\n7\t        let tempDirectory = FileManager.default.temporaryDirectory\n8\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n9\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n10\t        let fileURL = tempDirectory.appendingPathComponent(\"sample.md\")\n11\t        try \"# Title\\n\\nHello\".write(to: fileURL, atomically: true, encoding: .utf8)\n12\t\n13\t        let state = AppState()\n14\t        state.open(url: fileURL)\n15\t\n16\t        XCTAssertEqual(state.document?.url, fileURL)\n17\t        XCTAssertEqual(state.document?.rawText, \"# Title\\n\\nHello\")\n18\t        XCTAssertEqual(state.windowTitle, \"sample.md\")\n19\t        XCTAssertNil(state.errorMessage)\n20\t    }\n21\t\n22\t    func testReloadReadsLatestFileContents() throws {\n23\t        let tempDirectory = FileManager.default.temporaryDirectory\n24\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n25\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n26\t        let fileURL = tempDirectory.appendingPathComponent(\"reload.md\")\n27\t        try \"old\".write(to: fileURL, atomically: true, encoding: .utf8)\n28\t\n29\t        let state = AppState()\n30\t        state.open(url: fileURL)\n31\t        try \"new\".write(to: fileURL, atomically: true, encoding: .utf8)\n32\t        state.reload()\n33\t\n34\t        XCTAssertEqual(state.document?.rawText, \"new\")\n35\t        XCTAssertNil(state.errorMessage)\n36\t    }\n37\t\n38\t    func testAutoReloadsWhenOpenedFileChangesExternally() async throws {\n39\t        let tempDirectory = FileManager.default.temporaryDirectory\n40\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n41\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n42\t        let fileURL = tempDirectory.appendingPathComponent(\"watch.md\")\n43\t        try \"before\".write(to: fileURL, atomically: true, encoding: .utf8)\n44\t\n45\t        let state = AppState()\n46\t        state.open(url: fileURL)\n47\t\n48\t        try \"after\".write(to: fileURL, atomically: true, encoding: .utf8)\n49\t\n50\t        for _ in 0..<30 {\n51\t            if state.document?.rawText == \"after\" {\n52\t                break\n53\t            }\n54\t            try await Task.sleep(for: .milliseconds(100))\n55\t        }\n56\t\n57\t        XCTAssertEqual(state.document?.rawText, \"after\")\n58\t        XCTAssertNil(state.errorMessage)\n59\t    }\n60\t\n61\t    func testReloadWithoutDocumentIsNoOp() {\n62\t        let state = AppState()\n63\t        state.reload()\n64\t\n65\t        XCTAssertNil(state.document)\n66\t        XCTAssertNil(state.errorMessage)\n67\t        XCTAssertEqual(state.windowTitle, \"Markdown Preview\")\n68\t    }\n69\t\n70\t    func testOpenFailureSetsError() {\n71\t        let state = AppState()\n72\t        let missingURL = URL(fileURLWithPath: \"/tmp/\\(UUID().uuidString)/missing.md\")\n73\t\n74\t        state.open(url: missingURL)\n75\t\n76\t        XCTAssertNil(state.document)\n77\t        XCTAssertNotNil(state.errorMessage)\n78\t        XCTAssertEqual(state.windowTitle, \"Markdown Preview\")\n79\t    }\n80\t\n81\t    func testOpenFailurePreservesExistingDocument() throws {\n82\t        let tempDirectory = FileManager.default.temporaryDirectory\n83\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n84\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n85\t        let fileURL = tempDirectory.appendingPathComponent(\"stable.md\")\n86\t        try \"stable\".write(to: fileURL, atomically: true, encoding: .utf8)\n87\t\n88\t        let state = AppState()\n89\t        state.open(url: fileURL)\n90\t        let missingURL = tempDirectory.appendingPathComponent(\"missing.md\")\n91\t\n92\t        state.open(url: missingURL)\n93\t\n94\t        XCTAssertEqual(state.document?.url, fileURL)\n95\t        XCTAssertEqual(state.document?.rawText, \"stable\")\n96\t        XCTAssertEqual(state.windowTitle, \"stable.md\")\n97\t        XCTAssertNotNil(state.errorMessage)\n98\t    }\n99\t\n100\t    func testSaveUpdatesDocumentWithoutReloading() throws {\n101\t        let tempDirectory = FileManager.default.temporaryDirectory\n102\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n103\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n104\t        let fileURL = tempDirectory.appendingPathComponent(\"save.md\")\n105\t        try \"original\".write(to: fileURL, atomically: true, encoding: .utf8)\n106\t\n107\t        let state = AppState()\n108\t        state.open(url: fileURL)\n109\t\n110\t        state.save(text: \"modified\")\n111\t\n112\t        XCTAssertEqual(state.document?.rawText, \"modified\")\n113\t    }\n114\t\n115\t    func testSaveDoesNotRestartFileMonitoring() throws {\n116\t        let tempDirectory = FileManager.default.temporaryDirectory\n117\t            .appendingPathComponent(UUID().uuidString, isDirectory: true)\n118\t        try FileManager.default.createDirectory(at: tempDirectory, withIntermediateDirectories: true)\n119\t        let fileURL = tempDirectory.appendingPathComponent(\"monitor.md\")\n120\t        try \"initial\".write(to: fileURL, atomically: true, encoding: .utf8)\n121\t\n122\t        let state = AppState()\n123\t        state.open(url: fileURL)\n124\t\n125\t        // Get the current file monitoring task\n126\t        let firstPollingTask = Mirror(reflecting: state).children.first { $0.label == \"filePollingTask\" }?.value as? Task<Void, Never>\n127\t\n128\t        state.save(text: \"modified\")\n129\t\n130\t        // The polling task should NOT have been restarted\n131\t        let secondPollingTask = Mirror(reflecting: state).children.first { $0.label == \"filePollingTask\" }?.value as? Task<Void, Never>\n132\t\n133\t        XCTAssertTrue(firstPollingTask === secondPollingTask, \"filePollingTask should not be recreated on save\")\n134\t    }\n135\t}\n136\t"}]},"parent_tool_use_id":"call_function_goocvjbg6frx_1","session_id":"41c019a8-071d-4d72-b209-d88f767a956d","uuid":"5303ee64-b7ba-40e4-ad70-7ca25792405d","timestamp":"2026-04-19T09:07:47.114Z"}
