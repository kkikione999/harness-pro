{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_wt9obrzvt1ij_2","type":"tool_result","content":"1\timport AppKit\n2\timport Combine\n3\timport SwiftUI\n4\t\n5\t@MainActor\n6\tfinal class AppWindowManager {\n7\t    static let shared = AppWindowManager()\n8\t\n9\t    private var controllers: [ObjectIdentifier: PreviewWindowController] = [:]\n10\t    private weak var activeController: PreviewWindowController?\n11\t\n12\t    private init() { }\n13\t\n14\t    func openWindow(with url: URL? = nil) {\n15\t        let appState = AppState(initialURL: url)\n16\t        let controller = PreviewWindowController(\n17\t            appState: appState,\n18\t            onOpenFile: { [weak self] in\n19\t                self?.showOpenPanel()\n20\t            },\n21\t            onClose: { [weak self] controller in\n22\t                self?.remove(controller)\n23\t            }\n24\t        )\n25\t\n26\t        let identifier = ObjectIdentifier(controller)\n27\t        controllers[identifier] = controller\n28\t        controller.showWindow(nil)\n29\t        controller.window?.makeKeyAndOrderFront(nil)\n30\t        activeController = controller\n31\t        NSApp.activate(ignoringOtherApps: true)\n32\t    }\n33\t\n34\t    func openWindows(with urls: [URL]) {\n35\t        for url in urls {\n36\t            openWindow(with: url)\n37\t        }\n38\t    }\n39\t\n40\t    func showOpenPanel() {\n41\t        let panel = NSOpenPanel()\n42\t        panel.allowedContentTypes = MarkdownFileType.allowedContentTypes\n43\t        panel.allowsMultipleSelection = true\n44\t        panel.canChooseDirectories = false\n45\t        panel.canChooseFiles = true\n46\t        panel.prompt = \"Open\"\n47\t\n48\t        if panel.runModal() == .OK {\n49\t            openWindows(with: panel.urls)\n50\t        }\n51\t    }\n52\t\n53\t    func reloadActiveWindow() {\n54\t        activeController?.appState.reload()\n55\t    }\n56\t\n57\t    func handleLink(url: URL, baseURL: URL?) {\n58\t        switch MarkdownInteractions.linkAction(for: url, baseURL: baseURL) {\n59\t        case .ignore:\n60\t            return\n61\t        case .openMarkdownPreview(let markdownURL):\n62\t            if FileManager.default.isReadableFile(atPath: markdownURL.path) {\n63\t                openWindow(with: markdownURL)\n64\t            } else {\n65\t                activeController?.appState.errorMessage = \"Unable to open linked file: \\(markdownURL.lastPathComponent)\"\n66\t                NSSound.beep()\n67\t            }\n68\t        case .openExternal(let externalURL):\n69\t            NSWorkspace.shared.open(externalURL)\n70\t        }\n71\t    }\n72\t\n73\t    func activate(_ controller: PreviewWindowController) {\n74\t        activeController = controller\n75\t    }\n76\t\n77\t    private func remove(_ controller: PreviewWindowController) {\n78\t        if activeController === controller {\n79\t            activeController = controllers.values.first { $0 !== controller }\n80\t        }\n81\t        controllers.removeValue(forKey: ObjectIdentifier(controller))\n82\t    }\n83\t}\n84\t\n85\t@MainActor\n86\tfinal class PreviewWindowController: NSWindowController, NSWindowDelegate {\n87\t    let appState: AppState\n88\t\n89\t    private var cancellables: Set<AnyCancellable> = []\n90\t    private let onClose: (PreviewWindowController) -> Void\n91\t\n92\t    init(\n93\t        appState: AppState,\n94\t        onOpenFile: @escaping () -> Void,\n95\t        onClose: @escaping (PreviewWindowController) -> Void\n96\t    ) {\n97\t        self.appState = appState\n98\t        self.onClose = onClose\n99\t\n100\t        let rootView = ContentView(appState: appState, onOpenFile: onOpenFile)\n101\t            .frame(minWidth: 900, minHeight: 620)\n102\t        let hostingController = NSHostingController(rootView: rootView)\n103\t\n104\t        let window = NSWindow(contentViewController: hostingController)\n105\t        window.setContentSize(NSSize(width: 980, height: 700))\n106\t        window.minSize = NSSize(width: 900, height: 620)\n107\t        window.title = appState.windowTitle\n108\t        window.isReleasedWhenClosed = false\n109\t        window.center()\n110\t\n111\t        super.init(window: window)\n112\t\n113\t        window.delegate = self\n114\t\n115\t        appState.$windowTitle\n116\t            .receive(on: RunLoop.main)\n117\t            .sink { [weak window] title in\n118\t                window?.title = title\n119\t            }\n120\t            .store(in: &cancellables)\n121\t    }\n122\t\n123\t    @available(*, unavailable)\n124\t    required init?(coder: NSCoder) {\n125\t        nil\n126\t    }\n127\t\n128\t    func windowWillClose(_ notification: Notification) {\n129\t        onClose(self)\n130\t    }\n131\t\n132\t    func windowDidBecomeMain(_ notification: Notification) {\n133\t        AppWindowManager.shared.activate(self)\n134\t    }\n135\t}\n136\t"}]},"parent_tool_use_id":"call_function_goocvjbg6frx_1","session_id":"41c019a8-071d-4d72-b209-d88f767a956d","uuid":"aaafd54e-46ea-4eef-90c2-77e3cde83063","timestamp":"2026-04-19T09:07:37.139Z"}
