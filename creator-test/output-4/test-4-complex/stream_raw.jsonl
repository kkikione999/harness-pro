l() {\n58\t        let panel = NSOpenPanel()\n59\t        panel.allowedContentTypes = MarkdownFileType.allowedContentTypes\n60\t        panel.allowsMultipleSelection = true\n61\t        panel.canChooseDirectories = false\n62\t        panel.canChooseFiles = true\n63\t        panel.prompt = \"Open\"\n64\t\n65\t        if panel.runModal() == .OK {\n66\t            openWindows(with: panel.urls)\n67\t        }\n68\t    }\n69\t\n70\t    func reloadActiveWindow() {\n71\t        activeController?.appState.reload()\n72\t    }\n73\t\n74\t    func handleLink(url: URL, baseURL: URL?) {\n75\t        switch MarkdownInteractions.linkAction(for: url, baseURL: baseURL) {\n76\t        case .ignore:\n77\t            return\n78\t        case .openMarkdownPreview(let markdownURL):\n79\t            if FileManager.default.isReadableFile(atPath: markdownURL.path) {\n80\t                openWindow(with: markdownURL)\n81\t            } else {\n82\t                activeController?.appState.errorMessage = \"Unable to open linked file: \\(markdownURL.lastPathComponent)\"\n83\t                NSSound.beep()\n84\t            }\n85\t        case .openExternal(let externalURL):\n86\t            NSWorkspace.shared.open(externalURL)\n87\t        }\n88\t    }\n89\t\n90\t    func activate(_ controller: PreviewWindowController) {\n91\t        activeController = controller\n92\t    }\n93\t\n94\t    private func remove(_ controller: PreviewWindowController) {\n95\t        if activeController === controller {\n96\t            activeController = controllers.values.first { $0 !== controller }\n97\t        }\n98\t        controllers.removeValue(forKey: ObjectIdentifier(controller))\n99\t    }\n100\t}\n101\t\n102\t@MainActor\n103\tfinal class PreviewWindowController: NSWindowController, NSWindowDelegate {\n104\t    let appState: AppState\n105\t\n106\t    private var cancellables: Set<AnyCancellable> = []\n107\t    private let onClose: (PreviewWindowController) -> Void\n108\t\n109\t    init(\n110\t        appS