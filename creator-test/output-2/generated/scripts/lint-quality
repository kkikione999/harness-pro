#!/bin/bash
# Lint code quality rules

set -euo pipefail

# Allow override via environment variable for testing
if [ -n "${MARKDOWN_PREVIEW_ROOT:-}" ]; then
    ROOT_DIR="$MARKDOWN_PREVIEW_ROOT"
else
    ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi
SOURCE_DIR="${ROOT_DIR}/Sources"
MAX_LINES=500
VIOLATIONS=0

echo "Checking code quality..."
echo ""

# Check 1: File line count
echo "Checking file lengths (max $MAX_LINES lines)..."
if [ -d "$SOURCE_DIR" ]; then
    for file in $(find "$SOURCE_DIR" -name "*.swift" -type f 2>/dev/null); do
        filename="$(basename "$file")"
        # Skip .build directory
        case "$file" in
            *.build/*) continue ;;
        esac
        line_count=$(wc -l < "$file")
        if [[ "$line_count" -gt "$MAX_LINES" ]]; then
            echo "  ✗ $filename: $line_count lines (exceeds $MAX_LINES)"
            VIOLATIONS=$((VIOLATIONS + 1))
        else
            echo "  ✓ $filename: $line_count lines"
        fi
    done
fi
echo ""

# Check 2: No print statements (should use os.Logger or structured logging)
echo "Checking for print statements (use os.Logger instead)..."
if [ -d "$SOURCE_DIR" ]; then
    for file in $(find "$SOURCE_DIR" -name "*.swift" -type f 2>/dev/null); do
        case "$file" in
            *.build/*|*/Tests/*) continue ;;
        esac
        if grep -q 'print(' "$file" 2>/dev/null; then
            echo "  ✗ $(basename "$file"): contains print() - use os.Logger"
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    done
fi
echo ""

# Check 3: Swift concurrency - @MainActor on relevant classes
# Note: Only L4 (Interface) classes with shared mutable state need @MainActor
# L0 (Types) and L1 (Utils) are typically @Sendable by nature
echo "Checking @MainActor annotations (L4 classes only)..."
if [ -d "$SOURCE_DIR" ]; then
    for file in $(find "$SOURCE_DIR" -name "*.swift" -type f 2>/dev/null); do
        case "$file" in
            *.build/*|*/Tests/*) continue ;;
        esac
        filename="$(basename "$file")"
        # Only check L4 files (AppState, AppWindowManager, AppDelegate, ContentView)
        case "$filename" in
            AppState|AppWindowManager|ContentView) ;;
            *) continue ;;
        esac
        if grep -q '@MainActor' "$file"; then
            echo "  ✓ $filename: has @MainActor"
        else
            echo "  ○ $filename: missing @MainActor (consider adding for thread safety)"
        fi
    done
fi
echo ""

if [[ "$VIOLATIONS" -eq 0 ]]; then
    echo "✓ No quality violations found"
else
    echo "Found $VIOLATIONS violation(s)"
fi

exit $VIOLATIONS
