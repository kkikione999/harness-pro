#!/bin/bash
# Lint architecture: check layer dependencies
# Educational error messages explain what, which rule, why wrong, and how to fix

set -euo pipefail

# Layer mapping (inferred from import analysis)
# Format: "filename:layer"
LAYERS="
MarkdownFileType:0
MarkdownRenderMode:0
LinkHandling:1
MarkdownInteractions:3
AppState:4
AppDelegate:4
AppWindowManager:4
MarkdownPreviewApp:4
MarkdownPreviewView:4
ContentView:4
ReadOnlyTextView:4
"

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SRC_DIR="$ROOT_DIR/Sources/MarkdownPreview"
VIOLATIONS=0

# Get layer for a given filename
get_layer() {
    local filename="$1"
    local line
    while IFS= read -r line; do
        if [[ "$line" =~ ^${filename}: ]]; then
            echo "${line#*:}"
            return 0
        fi
    done <<< "$LAYERS"
    echo "99"
    return 0
}

# Educational error format (4 parts: WHAT, RULE, WHY WRONG, HOW TO FIX)
print_violation() {
    local source="$1" target="$2" src_layer="$3" tgt_layer="$4"
    VIOLATIONS=$((VIOLATIONS + 1))
    echo "✗ VIOLATION FOUND"
    echo ""
    echo "File: $source (Layer $src_layer)"
    echo "Imports: $target (Layer $tgt_layer)"
    echo ""
    echo "THE RULE: Higher layers can import lower layers; lower CANNOT import higher."
    echo "WHY WRONG: Layer $src_layer depends on Layer $tgt_layer."
    echo "  This creates tight coupling between layers with different responsibilities."
    echo "  Business logic (L3) should not depend on UI (L4), and utils (L1) should not depend on services (L3)."
    echo ""
    echo "HOW TO FIX (choose one):"
    echo "  1. Move the dependency to a lower layer (create a protocol in L1/L2)"
    echo "  2. Pass needed value as a parameter from the calling layer"
    echo "  3. Move the dependent code to the appropriate layer"
    echo ""
    echo "Example fix:"
    echo "  Before: $source (L$src_layer) imports $target (L$tgt_layer)"
    echo "  After:  Create a protocol in L1/L2, inject the dependency"
    echo ""
}

check_file() {
    local file="$1"
    local filename="$(basename "$file" .swift)"
    local src_layer
    src_layer=$(get_layer "$filename")

    if [[ "$src_layer" -eq 99 ]]; then
        return 0  # Unknown layer, skip
    fi

    # Check imports in the file
    local imports
    imports=$(grep -h "^import " "$file" 2>/dev/null || true)

    while IFS= read -r import_line; do
        [[ -z "$import_line" ]] && continue
        local imported_module
        imported_module=$(echo "$import_line" | awk '{print $2}')

        # Check if importing another internal module we track
        local tgt_layer
        tgt_layer=$(get_layer "$imported_module")

        if [[ "$tgt_layer" -ne 99 ]] && [[ "$src_layer" -gt "$tgt_layer" ]]; then
            print_violation "$filename.swift" "$imported_module.swift" "$src_layer" "$tgt_layer"
        fi
    done <<< "$imports"
}

echo "Checking layer dependencies..."
echo ""

for file in "$SRC_DIR"/*.swift; do
    if [ -f "$file" ]; then
        check_file "$file"
    fi
done

if [[ "$VIOLATIONS" -eq 0 ]]; then
    echo "✓ No layer violations found"
    echo ""
    echo "Layer structure:"
    echo "  L0: Types (MarkdownFileType, MarkdownRenderMode)"
    echo "  L1: Utils (LinkHandling)"
    echo "  L2: Config (not used)"
    echo "  L3: Services (MarkdownInteractions)"
    echo "  L4: Interface (AppState, AppDelegate, AppWindowManager, Views)"
else
    echo ""
    echo "Found $VIOLATIONS violation(s)"
fi

exit $VIOLATIONS
