#!/bin/bash
# lint-deps - Validate layer dependencies (L0→L1→L3→L4)
# Bash 3.2 compatible

set -euo pipefail

SOURCES_DIR="Sources/MarkdownPreview"
ERRORS=0

# Layer mapping (inferred from import analysis)
# Format: "filename:layer"
LAYERS="
MarkdownFileType:0
MarkdownRenderMode:0
LinkHandling:0
ReadOnlyTextView:1
AppState:3
MarkdownInteractions:3
AppWindowManager:4
ContentView:4
MarkdownPreviewApp:4
AppDelegate:4
MarkdownPreviewView:4
"

# External modules to skip
EXTERNAL_MODULES="AppKit Foundation SwiftUI MarkdownUI UniformTypeIdentifiers Combine OS"

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SRC_DIR="$ROOT_DIR/$SOURCES_DIR"

is_external() {
    local mod="$1"
    for ext in $EXTERNAL_MODULES; do
        [[ "$mod" == "$ext" ]] && return 0
    done
    return 1
}

get_layer() {
    local filename="$1"
    local line
    while IFS= read -r line; do
        if [[ "$line" =~ ^${filename}: ]]; then
            echo "${line#*:}"
            return 0
        fi
    done <<< "$LAYERS"
    echo "99"
    return 0
}

print_violation() {
    local source="$1" target="$2" src_layer="$3" tgt_layer="$4"
    ERRORS=$((ERRORS + 1))
    echo "✗ VIOLATION FOUND"
    echo ""
    echo "File: $source (Layer $src_layer)"
    echo "Imports: $target (Layer $tgt_layer)"
    echo ""
    echo "THE RULE: Higher layers can import lower layers; lower CANNOT import higher."
    echo "WHY WRONG: Layer $src_layer depends on Layer $tgt_layer."
    echo "  This creates tight coupling between layers with different responsibilities."
    echo "  Business logic (L3) should not depend on UI (L4), and utils (L1) should not depend on services (L3)."
    echo ""
    echo "HOW TO FIX (choose one):"
    echo "  1. Move the dependency to a lower layer (create a protocol in L1/L2)"
    echo "  2. Pass needed value as a parameter from the calling layer"
    echo "  3. Move the dependent code to the appropriate layer"
    echo ""
}

check_file() {
    local file="$1"
    local filename="$(basename "$file" .swift)"
    local src_layer
    src_layer=$(get_layer "$filename")

    if [[ "$src_layer" -eq 99 ]]; then
        return 0
    fi

    # Get imports from this file
    local imports
    imports=$(grep -h "^import " "$file" 2>/dev/null || true)

    while IFS= read -r import_line; do
        [[ -z "$import_line" ]] && continue
        local imported_module
        imported_module=$(echo "$import_line" | awk '{print $2}')

        is_external "$imported_module" && continue

        # Check if it's an internal module we track
        local tgt_layer
        tgt_layer=$(get_layer "$imported_module")

        if [[ "$tgt_layer" -eq 99 ]]; then
            continue
        fi

        # Violation: lower layer importing higher layer
        if [[ "$src_layer" -gt "$tgt_layer" ]]; then
            print_violation "$filename.swift" "$imported_module.swift" "$src_layer" "$tgt_layer"
        fi
    done <<< "$imports"
}

echo "=== Layer Dependency Check ==="
echo ""

for file in "$SRC_DIR"/*.swift; do
    if [[ -f "$file" ]]; then
        check_file "$file"
    fi
done

echo ""
if [[ $ERRORS -eq 0 ]]; then
    echo "✓ All layer dependencies are valid"
    echo ""
    echo "Layer structure:"
    echo "  L0: Types (MarkdownFileType, MarkdownRenderMode, LinkHandling)"
    echo "  L1: Utils (ReadOnlyTextView)"
    echo "  L2: Config (not used)"
    echo "  L3: Services (AppState, MarkdownInteractions)"
    echo "  L4: Interface (AppWindowManager, ContentView, AppDelegate, etc.)"
    exit 0
else
    echo "✗ Found $ERRORS layer dependency violation(s)"
    exit 1
fi
