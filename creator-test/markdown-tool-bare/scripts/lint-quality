#!/bin/zsh
# Lint code quality for Swift projects

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SOURCES_DIR="$ROOT_DIR/Sources"
MAX_LINES=500
VIOLATIONS=0

echo "Checking Swift code quality..."

# Check 1: File line count
echo "  Checking file lengths (max $MAX_LINES lines)..."
while IFS= read -r -d '' file; do
    lines=$(wc -l < "$file" | tr -d ' ')
    if [[ "$lines" -gt "$MAX_LINES" ]]; then
        echo "  VIOLATION: $(basename "$file") has $lines lines (max $MAX_LINES)"
        VIOLATIONS=$((VIOLATIONS + 1))
    fi
done < <(find "$SOURCES_DIR" -name "*.swift" -print0)

# Check 2: No print() statements in production code (use os.Logger)
echo "  Checking for print() statements..."
while IFS= read -r -d '' file; do
    if grep -qE '^\s*print\(' "$file" 2>/dev/null; then
        if [[ "$file" != *"/Tests/"* ]]; then
            echo "  VIOLATION: $(basename "$file") contains print() - use os.Logger instead"
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    fi
done < <(find "$SOURCES_DIR" -name "*.swift" -print0)

# Check 3: No force unwraps in production code
echo "  Checking for force unwraps..."
while IFS= read -r -d '' file; do
    if grep -qE '[a-zA-Z]\!' "$file" 2>/dev/null; then
        # Exclude @IBOutlet and test assertions which commonly use !
        if [[ "$file" != *"/Tests/"* ]]; then
            count=$(grep -cE '[a-zA-Z]\!' "$file" 2>/dev/null || echo "0")
            if [[ "$count" -gt 3 ]]; then
                echo "  WARNING: $(basename "$file") has $count force unwrap(s) - review for safety"
            fi
        fi
    fi
done < <(find "$SOURCES_DIR" -name "*.swift" -print0)

echo ""
if [[ "$VIOLATIONS" -eq 0 ]]; then
    echo "OK: No quality violations found"
    exit 0
else
    echo "FAIL: Found $VIOLATIONS quality violation(s)"
    exit 1
fi
