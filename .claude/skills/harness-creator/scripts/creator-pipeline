#!/bin/bash
# creator-pipeline — 状态机 + 门控 (合一)
# 管理创作者管线的状态和前置条件检查
#
# 用法:
#   creator-pipeline init              创建初始状态
#   creator-pipeline check             输出当前状态
#   creator-pipeline advance <step> [k=v]...  标记步骤完成，附带产出物
#   creator-pipeline gate <step>       检查前置条件
#   creator-pipeline reset             清除状态

set -euo pipefail

STATE_DIR="harness/state"
STATE_FILE="${STATE_DIR}/creator-state.json"

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

cmd_init() {
  mkdir -p "$STATE_DIR"
  if [ -f "$STATE_FILE" ]; then
    local completed
    completed=$(jq -r '.steps_completed | length' "$STATE_FILE")
    if [ "$completed" -gt 0 ]; then
      echo "状态文件已存在，有 $completed 步已完成。"
      echo "继续未完成的工作: creator-pipeline check"
      echo "如需从头开始: creator-pipeline reset"
      return 0
    fi
    echo "状态文件已存在但无进度，继续使用。"
    return 0
  fi
  cat > "$STATE_FILE" <<EOF
{
  "mode": null,
  "language": null,
  "current_step": 0,
  "steps_completed": [],
  "audit_score": null,
  "layer_map": {},
  "files_written": []
}
EOF
  echo "初始化完成: $STATE_FILE"
}

cmd_check() {
  if [ ! -f "$STATE_FILE" ]; then
    echo "ERROR: 状态文件不存在。先运行: creator-pipeline init"
    exit 1
  fi
  echo "模式: $(jq -r '.mode // "未检测"' "$STATE_FILE")"
  echo "语言: $(jq -r '.language // "未检测"' "$STATE_FILE")"
  echo "当前步骤: $(jq -r '.current_step' "$STATE_FILE")"
  echo "已完成: $(jq -r '.steps_completed | join(", ") // "无"' "$STATE_FILE")"
  echo "审计得分: $(jq -r '.audit_score // "未评分"' "$STATE_FILE")"
  echo "层级映射: $(jq -r 'if .layer_map == {} then "未扫描" else "已有" end' "$STATE_FILE")"
  echo "已写文件: $(jq -r '.files_written | length' "$STATE_FILE") 个"
}

cmd_advance() {
  local step="${1:?用法: creator-pipeline advance <step> [key=value...]}"
  if [ ! -f "$STATE_FILE" ]; then
    echo "ERROR: 状态文件不存在"
    exit 1
  fi

  # 幂等：已完成则跳过
  if jq -e --argjson s "$step" '.steps_completed | index($s)' "$STATE_FILE" > /dev/null 2>&1; then
    echo "Step $step 已完成，跳过"
    return 0
  fi

  local tmp
  tmp=$(jq --argjson s "$step" --arg now "$(now)" \
    '.steps_completed += [$s] | .current_step = $s | .updated_at = $now' \
    "$STATE_FILE")

  # 处理 key=value 参数
  shift
  for arg in "$@"; do
    local key="${arg%%=*}"
    local val="${arg#*=}"
    # 尝试解析为 JSON (数字/布尔/对象)，否则当字符串
    if echo "$val" | jq -e . > /dev/null 2>&1; then
      tmp=$(jq --arg k "$key" --argjson v "$val" '.[$k] = $v' <<< "$tmp")
    else
      tmp=$(jq --arg k "$key" --arg v "$val" '.[$k] = $v' <<< "$tmp")
    fi
  done

  echo "$tmp" > "$STATE_FILE"
  echo "Step $step 完成 → $STATE_FILE"
}

cmd_gate() {
  local step="${1:?用法: creator-pipeline gate <step>}"
  if [ ! -f "$STATE_FILE" ]; then
    echo "BLOCKED: 状态文件不存在 (先运行 creator-pipeline init)"
    exit 1
  fi

  local completed
  completed=$(jq -r '.steps_completed[]' "$STATE_FILE" 2>/dev/null || true)

  has_step() { echo "$completed" | grep -qx "$1" 2>/dev/null; }

  case "$step" in
    1)
      echo "GATE PASSED: Step 1 (无前置条件)"
      ;;
    2)
      has_step 1 || { echo "BLOCKED: Step 1 未完成"; exit 1; }
      echo "GATE PASSED: Step 2"
      ;;
    3)
      has_step 2 || { echo "BLOCKED: Step 2 未完成"; exit 1; }
      local score
      score=$(jq -r '.audit_score // empty' "$STATE_FILE")
      [ -z "$score" ] && { echo "BLOCKED: audit_score 为空，请先完成审计"; exit 1; }
      local layers
      layers=$(jq -r 'if .layer_map == {} then "" else "ok" end' "$STATE_FILE")
      [ "$layers" != "ok" ] && { echo "BLOCKED: layer_map 为空，请先完成层级扫描"; exit 1; }
      echo "GATE PASSED: Step 3 (score=$score)"
      ;;
    4)
      has_step 3 || { echo "BLOCKED: Step 3 未完成"; exit 1; }
      local count
      count=$(jq -r '.files_written | length' "$STATE_FILE")
      [ "$count" -eq 0 ] && { echo "BLOCKED: files_written 为空，请先生成文件"; exit 1; }
      echo "GATE PASSED: Step 4 ($count files written)"
      ;;
    5)
      has_step 4 || { echo "BLOCKED: Step 4 未完成"; exit 1; }
      echo "GATE PASSED: Step 5"
      ;;
    *)
      echo "BLOCKED: 未知步骤号 $step (有效: 1-5)"
      exit 1
      ;;
  esac
}

cmd_reset() {
  if [ -f "$STATE_FILE" ]; then
    rm "$STATE_FILE"
    echo "已清除: $STATE_FILE"
  else
    echo "状态文件不存在，无需清除"
  fi
}

ACTION="${1:?用法: creator-pipeline <init|check|advance|gate|reset> [args]}"
shift

case "$ACTION" in
  init)     cmd_init "$@" ;;
  check)    cmd_check "$@" ;;
  advance)  cmd_advance "$@" ;;
  gate)     cmd_gate "$@" ;;
  reset)    cmd_reset "$@" ;;
  *)        echo "未知命令: $ACTION"; exit 1 ;;
esac
