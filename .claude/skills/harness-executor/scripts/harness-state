#!/bin/bash
# harness-state — 状态机管理脚本
# 管理 {project}/harness/state/{task-name}.json
#
# 用法:
#   harness-state init <task-name>           创建初始状态
#   harness-state check <task-name>          输出当前状态
#   harness-state advance <task> <step> [k=v]...  标记步骤完成
#   harness-state reset <task-name>          清除状态

set -euo pipefail

USAGE="用法: harness-state init|check|advance|reset <task> [args]"
ACTION="${1:?$USAGE}"
TASK="${2:?缺少 task-name}"

STATE_DIR="harness/state"
STATE_FILE="${STATE_DIR}/${TASK}.json"

now() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

case "$ACTION" in
  init)
    mkdir -p "$STATE_DIR"
    if [ -f "$STATE_FILE" ]; then
      echo "状态文件已存在: $STATE_FILE"
      echo "如需重置, 先运行: harness-state reset $TASK"
      exit 1
    fi
    cat > "$STATE_FILE" <<EOF
{
  "task": "${TASK}",
  "current_step": 0,
  "steps_completed": [],
  "complexity": null,
  "plan_path": null,
  "current_phase": null,
  "phases_completed": [],
  "validation_results": {},
  "review_result": null,
  "created_at": "$(now)",
  "updated_at": "$(now)"
}
EOF
    : > "${STATE_DIR}/${TASK}.trace.md"
    echo "初始化完成: $STATE_FILE"
    ;;

  check)
    if [ ! -f "$STATE_FILE" ]; then
      echo "ERROR: 状态文件不存在 ($STATE_FILE)"
      echo "先运行: harness-state init $TASK"
      exit 1
    fi
    echo "任务: $(jq -r '.task' "$STATE_FILE")"
    echo "当前步骤: $(jq -r '.current_step' "$STATE_FILE")"
    echo "已完成: $(jq -r '.steps_completed | join(", ") // "无"' "$STATE_FILE")"
    echo "复杂度: $(jq -r '.complexity // "未分类"' "$STATE_FILE")"
    ;;

  advance)
    STEP="${3:?用法: harness-state advance <task> <step> [key=value...]}"
    if [ ! -f "$STATE_FILE" ]; then
      echo "ERROR: 状态文件不存在"
      exit 1
    fi

    # 检查是否已完成
    if jq -e --argjson s "$STEP" '.steps_completed | index($s)' "$STATE_FILE" > /dev/null 2>&1; then
      echo "Step $STEP 已标记完成, 跳过"
      exit 0
    fi

    # 添加到已完成列表, 更新 current_step
    TMP=$(jq --argjson s "$STEP" \
      --arg now "$(now)" \
      '.steps_completed += [$s] | .current_step = $s | .updated_at = $now' \
      "$STATE_FILE")

    # 处理额外的 key=value 参数
    shift 3
    for arg in "$@"; do
      KEY="${arg%%=*}"
      VAL="${arg#*=}"
      TMP=$(jq --arg k "$KEY" --arg v "$VAL" '.[$k] = $v' <<< "$TMP")
    done

    echo "$TMP" > "$STATE_FILE"
    TRACE_FILE="${STATE_DIR}/${TASK}.trace.md"
    {
      echo "## Step ${STEP} ($(now))"
      for arg in "$@"; do echo "- ${arg}"; done
      echo ""
    } >> "$TRACE_FILE"
    echo "Step $STEP 完成 → $STATE_FILE"
    ;;

  reset)
    if [ -f "$STATE_FILE" ]; then
      rm "$STATE_FILE"
      rm -f "${STATE_DIR}/${TASK}.trace.md"
      echo "已清除: $STATE_FILE"
    else
      echo "状态文件不存在, 无需清除"
    fi
    ;;

  *)
    echo "未知命令: $ACTION"
    echo "用法: harness-state {init|check|advance|reset} <task> [args]"
    exit 1
    ;;
esac
