#!/bin/bash
# harness-gate — 门控检查脚本
# 检查进入某步骤的前置条件是否满足
#
# 用法: harness-gate <task-name> <target-step>
# 退出码: 0=通过, 1=阻止, 2=跳过(Simple不需要此步骤)

set -euo pipefail

TASK="${1:?用法: harness-gate <task> <step>}"
STEP="${2:?缺少目标步骤号}"

STATE_FILE="harness/state/${TASK}.json"

if [ ! -f "$STATE_FILE" ]; then
  echo "BLOCKED: 状态文件不存在 (先运行 harness-state init)"
  exit 1
fi

COMPLETED=$(jq -r '.steps_completed[]' "$STATE_FILE" 2>/dev/null || true)
COMPLEXITY=$(jq -r '.complexity // "unknown"' "$STATE_FILE")

has_step() {
  echo "$COMPLETED" | grep -qx "$1" 2>/dev/null
}

case "$STEP" in
  1)
    # Step 1 无前置条件
    echo "GATE PASSED: Step 1 (无前置条件)"
    exit 0
    ;;

  2)
    has_step 1 || { echo "BLOCKED: Step 1 未完成"; exit 1; }
    echo "GATE PASSED: Step 2"
    ;;

  3)
    has_step 2 || { echo "BLOCKED: Step 2 未完成"; exit 1; }
    echo "GATE PASSED: Step 3"
    ;;

  4)
    has_step 3 || { echo "BLOCKED: Step 3 未完成"; exit 1; }
    if [ "$COMPLEXITY" = "simple" ]; then
      echo "SKIP: Simple 任务无需计划 (Step 4)"
      exit 2
    fi
    echo "GATE PASSED: Step 4"
    ;;

  5)
    # Medium/Complex 需 Step 4 + 计划文件; Simple 直接到 Step 5
    if [ "$COMPLEXITY" = "simple" ]; then
      has_step 3 || { echo "BLOCKED: Step 3 未完成"; exit 1; }
    else
      has_step 4 || { echo "BLOCKED: Step 4 未完成"; exit 1; }
      PLAN=$(jq -r '.plan_path // empty' "$STATE_FILE")
      if [ -n "$PLAN" ] && [ ! -f "$PLAN" ]; then
        echo "BLOCKED: 计划文件不存在 ($PLAN)"
        exit 1
      fi
    fi
    echo "GATE PASSED: Step 5"
    ;;

  6)
    has_step 5 || { echo "BLOCKED: Step 5 未完成"; exit 1; }
    if [ "$COMPLEXITY" = "simple" ]; then
      echo "SKIP: Simple 任务无需交叉审查 (Step 6)"
      exit 2
    fi
    echo "GATE PASSED: Step 6"
    ;;

  7)
    if [ "$COMPLEXITY" = "simple" ]; then
      has_step 5 || { echo "BLOCKED: Step 5 未完成"; exit 1; }
    else
      has_step 6 || { echo "BLOCKED: Step 6 未完成"; exit 1; }
    fi
    echo "GATE PASSED: Step 7"
    ;;

  8)
    has_step 7 || { echo "BLOCKED: Step 7 未完成"; exit 1; }
    # 验证结果检查
    VAL_FAIL=$(jq -r 'to_entries[] | select(.key | startswith("validation_") and . != "validation_results") | select(.value != "passed") | .key' "$STATE_FILE" 2>/dev/null || true)
    if [ -n "$VAL_FAIL" ]; then
      echo "BLOCKED: 验证未全部通过 (失败项: $VAL_FAIL)"
      exit 1
    fi
    echo "GATE PASSED: Step 8"
    ;;

  *)
    echo "BLOCKED: 未知步骤号 $STEP (有效: 1-8)"
    exit 1
    ;;
esac
