// [HARNESS-INJECT-START: harness_init]
// Initialize harness control plane if enabled
if (process.env.HARNESS_CONTROL === '1') {
  import('./harness.js').then(({ setCorrelationId, harnessLog }) => {
    // Generate or use provided correlation ID
    const harnessId = process.env.HARNESS_CORRELATION_ID || crypto.randomUUID()
    setCorrelationId(harnessId)

    // Emit startup event
    harnessLog('harness_initialized', {
      version: '2.0',
      correlationId: harnessId,
      pid: process.pid,
    }, { component: 'bootstrap' })

    console.log(`[HARNESS] Control plane activated with correlation ID: ${harnessId}`)
  }).catch(() => {
    // Harness module not found, continue without it
  })
}
// [HARNESS-INJECT-END: harness_init]

