# ci-pipeline.yml — GitHub Actions CI for {{project-name}}
# Generated by progressive-scaffolding
#
# This CI pipeline runs the project's scaffolding verification:
# - Lint checks (Golden Principles + import direction)
# - Dependency cycle detection
# - Observability health checks
# - Build verification
#
# Place this file at: .github/workflows/ci.yml

name: CI

on:
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master]

jobs:
  lint:
    name: Lint Checks
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Check import direction
        run: |
          if [ -f ".harness/controllability/lint-import-direction.sh" ]; then
            .harness/controllability/lint-import-direction.sh --verbose
          fi

      - name: Run Golden Principle lints
        run: |
          if [ -f ".harness/controllability/Makefile" ]; then
            cd .harness/controllability && make lint
          elif [ -f "rules/scripts/check.py" ]; then
            python3 rules/scripts/check.py
          fi

  dependency-check:
    name: Dependency Analysis
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Detect cycles
        run: |
          if [ -f ".harness/controllability/analyze-deps.sh" ]; then
            .harness/controllability/analyze-deps.sh --cycles
          fi

  health:
    name: Health Check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Run observability health check
        run: |
          if [ -f ".harness/observability/health.sh" ]; then
            .harness/observability/health.sh --json
          fi

  verify:
    name: Verification
    runs-on: ubuntu-latest
    needs: [lint, dependency-check, health]
    if: always()
    steps:
      - uses: actions/checkout@v4

      - name: Run full verification
        run: |
          if [ -f ".harness/controllability/Makefile" ]; then
            cd .harness/controllability && make verify
          elif [ -f ".harness/controllability/verify.sh" ]; then
            .harness/controllability/verify.sh
          fi

      - name: Run automated tests
        run: |
          if [ -f ".harness/controllability/Makefile" ]; then
            cd .harness/controllability && make test-auto
          elif [ -f ".harness/controllability/test-auto.sh" ]; then
            .harness/controllability/test-auto.sh
          fi
