#!/usr/bin/env python3
from __future__ import annotations

"""
claude-plugin — CLI for managing Claude Code plugins outside the interactive session.

Usage:
    claude-plugin install <plugin>[@<marketplace>] [--version VERSION] [--scope SCOPE]
    claude-plugin uninstall <plugin>[@<marketplace>]
    claude-plugin list
    claude-plugin enable <plugin>[@<marketplace>]
    claude-plugin disable <plugin>[@<marketplace>]
    claude-plugin doctor

Examples:
    claude-plugin install harness-pro-plugin@harness-pro-marketplace
    claude-plugin install superpowers@superpowers-marketplace --scope user
    claude-plugin list
    claude-plugin uninstall harness-pro-plugin@harness-pro-marketplace
    claude-plugin enable harness-pro-plugin@harness-pro-marketplace
    claude-plugin doctor
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

CLAUDE_DIR = Path.home() / ".claude"
PLUGINS_DIR = CLAUDE_DIR / "plugins"
CACHE_DIR = PLUGINS_DIR / "cache"
MARKETPLACES_DIR = PLUGINS_DIR / "marketplaces"
INSTALLED_FILE = PLUGINS_DIR / "installed_plugins.json"
KNOWN_MARKETPLACES_FILE = PLUGINS_DIR / "known_marketplaces.json"
SETTINGS_FILE = CLAUDE_DIR / "settings.json"


def load_json(path: Path):
    if not path.exists():
        return {}
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def save_json(path: Path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)
        f.write("\n")


def load_installed():
    data = load_json(INSTALLED_FILE)
    if not data:
        return {"version": 2, "plugins": {}}
    return data


def save_installed(data):
    save_json(INSTALLED_FILE, data)


def load_settings():
    data = load_json(SETTINGS_FILE)
    if not data:
        return {}
    return data


def save_settings(data):
    save_json(SETTINGS_FILE, data)


def load_known_marketplaces():
    return load_json(KNOWN_MARKETPLACES_FILE)


def resolve_marketplace_path(marketplace_name: str) -> Path | None:
    """Return the root directory of a marketplace."""
    known = load_known_marketplaces()
    entry = known.get(marketplace_name)
    if not entry:
        return None
    loc = entry.get("installLocation")
    if loc:
        return Path(loc)
    return None


def load_marketplace_manifest(marketplace_name: str) -> dict | None:
    """Load marketplace.json from a marketplace root."""
    root = resolve_marketplace_path(marketplace_name)
    if not root:
        return None

    # Try .claude-plugin/marketplace.json first (new format)
    manifest_path = root / ".claude-plugin" / "marketplace.json"
    if manifest_path.exists():
        return load_json(manifest_path)

    # Fallback: marketplace.json in root
    manifest_path = root / "marketplace.json"
    if manifest_path.exists():
        return load_json(manifest_path)

    return None


def find_plugin_in_marketplace(marketplace_name: str, plugin_name: str) -> dict | None:
    """Find a plugin definition in a marketplace manifest."""
    manifest = load_marketplace_manifest(marketplace_name)
    if not manifest:
        return None
    plugins = manifest.get("plugins", [])
    for p in plugins:
        if p.get("name") == plugin_name:
            return p
    return None


def find_plugin_across_marketplaces(plugin_name: str) -> tuple[str, dict] | None:
    """Search for a plugin in all known marketplaces. Returns (marketplace_name, plugin_def)."""
    known = load_known_marketplaces()
    for marketplace_name in known:
        plugin_def = find_plugin_in_marketplace(marketplace_name, plugin_name)
        if plugin_def:
            return marketplace_name, plugin_def
    return None


def get_plugin_version(plugin_def: dict, marketplace_root: Path) -> str:
    """Extract version from plugin definition or plugin.json."""
    version = plugin_def.get("version")
    if version:
        return version

    # Try reading plugin.json
    source = plugin_def.get("source", "")
    if isinstance(source, str) and not source.startswith(("http", "git")):
        plugin_json_path = marketplace_root / source / ".claude-plugin" / "plugin.json"
        if not plugin_json_path.exists():
            plugin_json_path = marketplace_root / source / "plugin.json"
        if plugin_json_path.exists():
            manifest = load_json(plugin_json_path)
            return manifest.get("version", "unknown")

    return "unknown"


def get_git_commit_sha(path: Path) -> str | None:
    """Get current git commit SHA if path is a git repo."""
    try:
        result = subprocess.run(
            ["git", "-C", str(path), "rev-parse", "HEAD"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def copy_plugin_to_cache(marketplace_name: str, plugin_name: str, plugin_def: dict,
                         source_path: Path, version: str) -> Path:
    """Copy plugin source to cache directory."""
    target_dir = CACHE_DIR / marketplace_name / plugin_name / version

    if target_dir.exists():
        shutil.rmtree(target_dir)

    shutil.copytree(source_path, target_dir, ignore=shutil.ignore_patterns(
        ".git", ".DS_Store", "__pycache__", "*.pyc", ".venv"
    ))

    return target_dir


def install_plugin(plugin_name: str, marketplace_name: str | None, version: str | None,
                   scope: str = "user"):
    """Install a plugin from a marketplace."""

    # Resolve marketplace
    if not marketplace_name:
        result = find_plugin_across_marketplaces(plugin_name)
        if not result:
            print(f"Error: Plugin '{plugin_name}' not found in any known marketplace.")
            print(f"Known marketplaces: {', '.join(load_known_marketplaces().keys())}")
            sys.exit(1)
        marketplace_name, plugin_def = result
        print(f"Found '{plugin_name}' in marketplace '{marketplace_name}'")
    else:
        plugin_def = find_plugin_in_marketplace(marketplace_name, plugin_name)
        if not plugin_def:
            print(f"Error: Plugin '{plugin_name}' not found in marketplace '{marketplace_name}'.")
            sys.exit(1)

    marketplace_root = resolve_marketplace_path(marketplace_name)
    if not marketplace_root:
        print(f"Error: Cannot resolve path for marketplace '{marketplace_name}'.")
        sys.exit(1)

    # Resolve source path
    source = plugin_def.get("source", "")
    if isinstance(source, dict):
        # Remote source (url, git-subdir) — not yet supported in this simple CLI
        print(f"Error: Remote plugin sources (url/git) are not yet supported by this CLI.")
        print(f"Source: {source}")
        print(f"Please install this plugin via the interactive 'mcp' command in Claude Code.")
        sys.exit(1)

    # Local relative path
    if isinstance(source, str):
        if source.startswith(("http://", "https://", "git@")):
            print(f"Error: Remote plugin sources are not yet supported by this CLI.")
            print(f"Please install this plugin via the interactive 'mcp' command in Claude Code.")
            sys.exit(1)
        source_path = marketplace_root / source
    else:
        source_path = marketplace_root

    if not source_path.exists():
        print(f"Error: Source path does not exist: {source_path}")
        sys.exit(1)

    # Determine version
    if not version:
        version = get_plugin_version(plugin_def, marketplace_root)

    # Copy to cache
    print(f"Installing {plugin_name}@{marketplace_name} (v{version})...")
    install_path = copy_plugin_to_cache(marketplace_name, plugin_name, plugin_def,
                                         source_path, version)
    print(f"  Cached to: {install_path}")

    # Get git commit SHA
    git_sha = get_git_commit_sha(source_path)

    # Build install entry
    now = datetime.now(timezone.utc).isoformat()
    entry = {
        "scope": scope,
        "installPath": str(install_path),
        "version": version,
        "installedAt": now,
        "lastUpdated": now,
    }
    if git_sha:
        entry["gitCommitSha"] = git_sha

    if scope == "project":
        entry["projectPath"] = str(Path.cwd())

    # Update installed_plugins.json
    installed = load_installed()
    key = f"{plugin_name}@{marketplace_name}"

    # Remove existing entries for this key
    installed["plugins"][key] = [entry]
    save_installed(installed)
    print(f"  Registered in installed_plugins.json")

    # Enable in settings.json
    settings = load_settings()
    enabled = settings.setdefault("enabledPlugins", {})
    enabled[key] = True
    save_settings(settings)
    print(f"  Enabled in settings.json")

    print(f"\n✓ Successfully installed {plugin_name}@{marketplace_name} v{version}")
    print(f"  Restart Claude Code or run /reload to activate the plugin.")


def uninstall_plugin(plugin_name: str, marketplace_name: str | None):
    """Uninstall a plugin."""
    installed = load_installed()
    plugins = installed.get("plugins", {})

    # Find matching key
    keys_to_remove = []
    if marketplace_name:
        key = f"{plugin_name}@{marketplace_name}"
        if key in plugins:
            keys_to_remove.append(key)
    else:
        for key in plugins:
            if key.startswith(f"{plugin_name}@"):
                keys_to_remove.append(key)

    if not keys_to_remove:
        print(f"Error: Plugin '{plugin_name}' is not installed.")
        sys.exit(1)

    settings = load_settings()
    enabled = settings.get("enabledPlugins", {})

    for key in keys_to_remove:
        entries = plugins.pop(key, [])
        enabled.pop(key, None)

        # Remove cache directories
        for entry in entries:
            install_path = Path(entry.get("installPath", ""))
            if install_path.exists() and CACHE_DIR in install_path.parents:
                shutil.rmtree(install_path)
                print(f"  Removed cache: {install_path}")

        print(f"  Uninstalled: {key}")

    save_installed(installed)
    save_settings(settings)
    print(f"\n✓ Successfully uninstalled.")


def list_plugins():
    """List all installed plugins."""
    installed = load_installed()
    plugins = installed.get("plugins", {})
    settings = load_settings()
    enabled = settings.get("enabledPlugins", {})

    if not plugins:
        print("No plugins installed.")
        return

    print(f"{'Plugin':<45} {'Version':<10} {'Scope':<10} {'Status':<10}")
    print("-" * 80)
    for key, entries in sorted(plugins.items()):
        for entry in entries:
            version = entry.get("version", "unknown")
            scope = entry.get("scope", "unknown")
            is_enabled = enabled.get(key, False)
            status = "enabled" if is_enabled else "disabled"
            print(f"{key:<45} {version:<10} {scope:<10} {status:<10}")


def enable_plugin(plugin_name: str, marketplace_name: str | None):
    """Enable a plugin."""
    settings = load_settings()
    enabled = settings.setdefault("enabledPlugins", {})

    if marketplace_name:
        key = f"{plugin_name}@{marketplace_name}"
        if key not in load_installed().get("plugins", {}):
            print(f"Error: Plugin '{key}' is not installed. Install it first.")
            sys.exit(1)
        enabled[key] = True
        print(f"✓ Enabled: {key}")
    else:
        installed = load_installed().get("plugins", {})
        matched = [k for k in installed if k.startswith(f"{plugin_name}@")]
        if not matched:
            print(f"Error: Plugin '{plugin_name}' is not installed.")
            sys.exit(1)
        for key in matched:
            enabled[key] = True
            print(f"✓ Enabled: {key}")

    save_settings(settings)
    print("  Restart Claude Code or run /reload to apply changes.")


def disable_plugin(plugin_name: str, marketplace_name: str | None):
    """Disable a plugin."""
    settings = load_settings()
    enabled = settings.get("enabledPlugins", {})

    if marketplace_name:
        key = f"{plugin_name}@{marketplace_name}"
        enabled.pop(key, None)
        print(f"✓ Disabled: {key}")
    else:
        keys_to_disable = [k for k in enabled if k.startswith(f"{plugin_name}@")]
        for key in keys_to_disable:
            enabled.pop(key, None)
            print(f"✓ Disabled: {key}")

    save_settings(settings)
    print("  Restart Claude Code or run /reload to apply changes.")


def doctor():
    """Run a quick health check on the plugin system."""
    print("Claude Code Plugin System Health Check")
    print("=" * 50)

    checks = [
        ("Claude config dir", CLAUDE_DIR.exists(), str(CLAUDE_DIR)),
        ("Plugins dir", PLUGINS_DIR.exists(), str(PLUGINS_DIR)),
        ("Cache dir", CACHE_DIR.exists(), str(CACHE_DIR)),
        ("Installed registry", INSTALLED_FILE.exists(), str(INSTALLED_FILE)),
        ("Known marketplaces registry", KNOWN_MARKETPLACES_FILE.exists(), str(KNOWN_MARKETPLACES_FILE)),
        ("Settings file", SETTINGS_FILE.exists(), str(SETTINGS_FILE)),
    ]

    all_ok = True
    for name, ok, detail in checks:
        status = "✓" if ok else "✗"
        if not ok:
            all_ok = False
        print(f"  {status} {name:<30} {detail}")

    known = load_known_marketplaces()
    print(f"\n  Known marketplaces ({len(known)}):")
    for name, info in known.items():
        source = info.get("source", {})
        src_type = source.get("source", "unknown")
        print(f"    • {name} (source: {src_type})")

    installed = load_installed()
    plugins = installed.get("plugins", {})
    print(f"\n  Installed plugins ({len(plugins)}):")
    for key in sorted(plugins):
        entries = plugins[key]
        versions = ", ".join(e.get("version", "unknown") for e in entries)
        print(f"    • {key} (v{versions})")

    if all_ok:
        print(f"\n✓ Plugin system is healthy.")
    else:
        print(f"\n✗ Some issues found. Run 'claude-plugin doctor' after fixing.")


def parse_plugin_ref(ref: str) -> tuple[str, str | None]:
    """Parse 'plugin@marketplace' or just 'plugin'."""
    if "@" in ref:
        parts = ref.rsplit("@", 1)
        return parts[0], parts[1]
    return ref, None


def main():
    parser = argparse.ArgumentParser(
        description="Manage Claude Code plugins from the command line.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  claude-plugin install harness-pro-plugin@harness-pro-marketplace
  claude-plugin install superpowers --scope user
  claude-plugin list
  claude-plugin uninstall harness-pro-plugin@harness-pro-marketplace
  claude-plugin enable harness-pro-plugin
  claude-plugin disable harness-pro-plugin
  claude-plugin doctor
        """,
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # install
    install_parser = subparsers.add_parser("install", help="Install a plugin")
    install_parser.add_argument("plugin", help="Plugin name or plugin@marketplace")
    install_parser.add_argument("--version", help="Specific version to install")
    install_parser.add_argument("--scope", choices=["user", "project"], default="user",
                                help="Installation scope (default: user)")

    # uninstall
    uninstall_parser = subparsers.add_parser("uninstall", help="Uninstall a plugin")
    uninstall_parser.add_argument("plugin", help="Plugin name or plugin@marketplace")

    # list
    subparsers.add_parser("list", help="List installed plugins")

    # enable
    enable_parser = subparsers.add_parser("enable", help="Enable a plugin")
    enable_parser.add_argument("plugin", help="Plugin name or plugin@marketplace")

    # disable
    disable_parser = subparsers.add_parser("disable", help="Disable a plugin")
    disable_parser.add_argument("plugin", help="Plugin name or plugin@marketplace")

    # doctor
    subparsers.add_parser("doctor", help="Run plugin system health check")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "install":
        plugin_name, marketplace_name = parse_plugin_ref(args.plugin)
        install_plugin(plugin_name, marketplace_name, args.version, args.scope)

    elif args.command == "uninstall":
        plugin_name, marketplace_name = parse_plugin_ref(args.plugin)
        uninstall_plugin(plugin_name, marketplace_name)

    elif args.command == "list":
        list_plugins()

    elif args.command == "enable":
        plugin_name, marketplace_name = parse_plugin_ref(args.plugin)
        enable_plugin(plugin_name, marketplace_name)

    elif args.command == "disable":
        plugin_name, marketplace_name = parse_plugin_ref(args.plugin)
        disable_plugin(plugin_name, marketplace_name)

    elif args.command == "doctor":
        doctor()


if __name__ == "__main__":
    main()
